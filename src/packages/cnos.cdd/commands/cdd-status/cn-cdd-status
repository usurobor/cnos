#!/usr/bin/env bash
# cn-cdd-status — read-only, evidence-derived CDD lifecycle status

set -euo pipefail

CYCLE_NUM=""
REPO_ROOT_OVERRIDE=""
POST_MARKER="CDD-Post-Merge-Closeout: complete"
TERMINAL_MARKER="CDD-Terminal-Closure: complete"

usage() {
  cat >&2 <<'EOF'
Usage:
  cn cdd-status <N>
  cn cdd-status --repo-root DIR <N>

Outputs five sections: issue, branch, artifacts, gate state, and next.
Gate state is ten repository-observable lifecycle facts; it does not pad the
result with permanently unknown conditions.
EOF
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo-root) [[ $# -ge 2 ]] || usage; REPO_ROOT_OVERRIDE="$2"; shift 2 ;;
    -h|--help) usage ;;
    -*) echo "Error: unknown option $1" >&2; usage ;;
    *) [[ -z "$CYCLE_NUM" ]] || { echo "Error: multiple cycle numbers specified" >&2; usage; }; CYCLE_NUM="$1"; shift ;;
  esac
done

[[ -n "$CYCLE_NUM" ]] || { echo "Error: cycle number required" >&2; usage; }
[[ "$CYCLE_NUM" =~ ^[1-9][0-9]*$ ]] || { echo "Error: cycle number must be a positive integer" >&2; exit 1; }

if [[ -n "$REPO_ROOT_OVERRIDE" ]]; then
  REPO_ROOT="$REPO_ROOT_OVERRIDE"
  git -C "$REPO_ROOT" rev-parse --git-dir >/dev/null 2>&1 || { echo "Error: not in a git repository" >&2; exit 1; }
else
  REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || { echo "Error: not in a git repository" >&2; exit 1; }
fi
cd "$REPO_ROOT"

ref_has_path() { git cat-file -e "$1:$2" 2>/dev/null; }
read_ref_file() { git show "$1:$2" 2>/dev/null || true; }

get_role_attribution() {
  local path="$1" ref="$2" author
  author="$(git log --format='%an' -n 1 "$ref" -- "$path" 2>/dev/null || true)"
  case "$author" in
    [Aa]lpha*|alpha@cdd.*) echo "(alpha)" ;;
    [Bb]eta*|beta@cdd.*) echo "(beta)" ;;
    [Gg]amma*|gamma@cdd.*) echo "(gamma)" ;;
    *) echo "(unknown)" ;;
  esac
}

echo "## Issue"
if command -v gh >/dev/null 2>&1; then
  ISSUE_JSON="$(gh issue view "$CYCLE_NUM" --json title,state,updatedAt 2>/dev/null || true)"
  if [[ -n "$ISSUE_JSON" ]]; then
    echo "  #$CYCLE_NUM: $(jq -r '.title' <<<"$ISSUE_JSON")"
    echo "  State: $(jq -r '.state' <<<"$ISSUE_JSON")"
    echo "  Updated: $(jq -r '.updatedAt' <<<"$ISSUE_JSON")"
  else
    echo "  ⚠️  Issue #$CYCLE_NUM not accessible"
  fi
else
  echo "  ⚠️  GitHub CLI not available - cannot read issue"
fi

echo
echo "## Branch"
BRANCH="origin/cycle/$CYCLE_NUM"
if git rev-parse --verify "$BRANCH" >/dev/null 2>&1; then
  echo "  $BRANCH at $(git rev-parse "$BRANCH")"
else
  LEGACY_MATCHES="$(git branch -r | grep -E "origin/.*$CYCLE_NUM" | head -5 || true)"
  if [[ -n "$LEGACY_MATCHES" ]]; then
    echo "  ⚠️  Legacy branch (canonical cycle/$CYCLE_NUM not found):"
    sed 's/^/    /' <<<"$LEGACY_MATCHES"
    BRANCH="$(head -1 <<<"$LEGACY_MATCHES" | xargs)"
    echo "  Using: $BRANCH at $(git rev-parse "$BRANCH")"
  else
    echo "  ❌ No branch found for cycle $CYCLE_NUM"
    BRANCH=""
  fi
fi

if git rev-parse --verify origin/main >/dev/null 2>&1; then
  MAIN_REF="origin/main"
else
  MAIN_REF="main"
fi

UNRELEASED_PATH=".cdd/unreleased/$CYCLE_NUM"
ARCHIVE_GAMMAS="$(git ls-tree -r --name-only "$MAIN_REF" .cdd/releases 2>/dev/null | grep -E "^\.cdd/releases/(docs/[0-9]{4}-[0-9]{2}-[0-9]{2}|[0-9]+\.[0-9]+\.[0-9]+)/$CYCLE_NUM/gamma-closeout\.md$" || true)"
ARCHIVE_PATH=""
if [[ -n "$ARCHIVE_GAMMAS" ]]; then
  ARCHIVE_PATH="$(head -1 <<<"$ARCHIVE_GAMMAS")"
  ARCHIVE_PATH="${ARCHIVE_PATH%/gamma-closeout.md}"
fi

STATE_REF=""
STATE_PATH=""
if ref_has_path "$MAIN_REF" "$UNRELEASED_PATH"; then
  STATE_REF="$MAIN_REF"; STATE_PATH="$UNRELEASED_PATH"
elif [[ -n "$ARCHIVE_PATH" ]]; then
  STATE_REF="$MAIN_REF"; STATE_PATH="$ARCHIVE_PATH"
elif [[ -n "$BRANCH" ]] && ref_has_path "$BRANCH" "$UNRELEASED_PATH"; then
  STATE_REF="$BRANCH"; STATE_PATH="$UNRELEASED_PATH"
fi

GAMMA_CONTENT=""
if [[ -n "$STATE_REF" ]] && ref_has_path "$STATE_REF" "$STATE_PATH/gamma-closeout.md"; then
  GAMMA_CONTENT="$(read_ref_file "$STATE_REF" "$STATE_PATH/gamma-closeout.md")"
fi

POST_MARKED=false
grep -Fxq "$POST_MARKER" <<<"$GAMMA_CONTENT" && POST_MARKED=true
BATCH_LINES="$(sed -nE 's/^CDD-Release-Batch: ([0-9]+\.[0-9]+\.[0-9]+|docs\/[0-9]{4}-[0-9]{2}-[0-9]{2})$/\1/p' <<<"$GAMMA_CONTENT")"
BATCH_COUNT="$(grep -c . <<<"$BATCH_LINES" || true)"
BATCH=""
[[ "$BATCH_COUNT" -eq 1 ]] && BATCH="$BATCH_LINES"

TAG_EXISTS=false
if [[ "$BATCH" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] && git rev-parse --verify "refs/tags/$BATCH" >/dev/null 2>&1; then
  TAG_EXISTS=true
fi

RELEASE_COMMITS="$(sed -nE 's/^CDD-Release-Commit: ([0-9a-f]{40})$/\1/p' <<<"$GAMMA_CONTENT")"
RELEASE_COMMIT_COUNT="$(grep -c . <<<"$RELEASE_COMMITS" || true)"
RELEASE_COMMIT=""
[[ "$RELEASE_COMMIT_COUNT" -eq 1 ]] && RELEASE_COMMIT="$RELEASE_COMMITS"

DISCONNECT_VALID=false
if [[ "$TAG_EXISTS" == true ]]; then
  DISCONNECT_VALID=true
elif [[ "$BATCH" =~ ^docs/[0-9]{4}-[0-9]{2}-[0-9]{2}$ && -n "$RELEASE_COMMIT" ]] &&
     git cat-file -e "$RELEASE_COMMIT^{commit}" 2>/dev/null &&
     git merge-base --is-ancestor "$RELEASE_COMMIT" "$MAIN_REF" 2>/dev/null; then
  DISCONNECT_VALID=true
fi

TERMINAL_MARKED=false
grep -Fxq "$TERMINAL_MARKER" <<<"$GAMMA_CONTENT" && TERMINAL_MARKED=true
TERMINAL_TAG="$(sed -nE 's/^CDD-Release-Tag: ([0-9]+\.[0-9]+\.[0-9]+)$/\1/p' <<<"$GAMMA_CONTENT" | head -1)"
ARCHIVE_SHA="$(sed -nE 's/^CDD-Archive-Commit: ([0-9a-f]{40})$/\1/p' <<<"$GAMMA_CONTENT" | head -1)"
ARCHIVE_BINDING=false
if [[ -n "$ARCHIVE_PATH" && -n "$ARCHIVE_SHA" ]] &&
   git cat-file -e "$ARCHIVE_SHA:$ARCHIVE_PATH/gamma-closeout.md" 2>/dev/null; then
  ARCHIVE_BINDING=true
fi

TERMINAL_DISCONNECT_BINDING=false
if [[ "$BATCH" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ && "$TERMINAL_TAG" == "$BATCH" && "$TAG_EXISTS" == true ]]; then
  TERMINAL_DISCONNECT_BINDING=true
elif [[ "$BATCH" =~ ^docs/[0-9]{4}-[0-9]{2}-[0-9]{2}$ && -n "$RELEASE_COMMIT" && "$DISCONNECT_VALID" == true ]]; then
  TERMINAL_DISCONNECT_BINDING=true
fi

TERMINAL_VALID=false
if [[ "$TERMINAL_MARKED" == true && "$TERMINAL_DISCONNECT_BINDING" == true && "$ARCHIVE_BINDING" == true ]]; then
  TERMINAL_VALID=true
fi

PHASE="in-progress"
if [[ "$TERMINAL_VALID" == true ]]; then
  PHASE="terminal"
elif [[ -n "$ARCHIVE_PATH" ]]; then
  PHASE="archived-but-not-terminal"
elif [[ "$DISCONNECT_VALID" == true ]]; then
  PHASE="disconnected-but-not-archived"
elif [[ "$POST_MARKED" == true && -n "$BATCH" ]]; then
  PHASE="release-pending"
elif ref_has_path "$MAIN_REF" "$UNRELEASED_PATH"; then
  PHASE="post-merge-incomplete"
fi

echo
echo "## Artifacts"
if [[ -n "$STATE_REF" ]]; then
  echo "  Source: $STATE_REF:$STATE_PATH"
  ARTIFACTS="$(git ls-tree -r --name-only "$STATE_REF" "$STATE_PATH/" 2>/dev/null | sort)"
  if [[ -n "$ARTIFACTS" ]]; then
    while IFS= read -r artifact; do
      echo "  $(basename "$artifact") $(get_role_attribution "$artifact" "$STATE_REF")"
    done <<<"$ARTIFACTS"
  else
    echo "  (none found)"
  fi
else
  echo "  (cannot read - branch or main record not found)"
fi

fact() { [[ "$1" == true ]] && echo "✓" || echo "✗"; }
path_fact() {
  if [[ -n "$STATE_REF" ]] && ref_has_path "$STATE_REF" "$STATE_PATH/$1"; then echo "✓"; else echo "✗"; fi
}

FACT_STATUS=(
  "$(path_fact self-coherence.md)"
  "$(path_fact beta-review.md)"
  "$(path_fact alpha-closeout.md)"
  "$(path_fact beta-closeout.md)"
  "$(path_fact gamma-closeout.md)"
  "$(fact "$POST_MARKED")"
  "$(fact "$([[ -n "$BATCH" ]] && echo true || echo false)")"
  "$(fact "$DISCONNECT_VALID")"
  "$(fact "$([[ -n "$ARCHIVE_PATH" ]] && echo true || echo false)")"
  "$(fact "$TERMINAL_VALID")"
)
FACT_LABELS=(
  "self-coherence.md observable"
  "beta-review.md observable"
  "alpha-closeout.md observable"
  "beta-closeout.md observable"
  "gamma-closeout.md observable"
  "nonterminal post-merge marker exact"
  "one canonical release-batch assignment"
  "assigned release disconnect observable (tag or docs merge commit)"
  "versioned cycle archive observable on main"
  "terminal marker + matching disconnect + resolvable archive binding"
)

echo
echo "## Gate State"
echo "  Lifecycle phase: $PHASE"
PASSED=0
for i in "${!FACT_STATUS[@]}"; do
  [[ "${FACT_STATUS[$i]}" == "✓" ]] && PASSED=$((PASSED + 1))
  printf "  %2d. %s %s\n" "$((i + 1))" "${FACT_STATUS[$i]}" "${FACT_LABELS[$i]}"
done
echo "  Status: $PASSED of ${#FACT_STATUS[@]} observable facts met"

echo
echo "## Next"
case "$PHASE" in
  terminal) echo "  ✅ Terminal: disconnect and archived terminal binding are mechanically coherent" ;;
  archived-but-not-terminal) echo "  → Append γ terminal seal binding the assigned disconnect and archive commit" ;;
  disconnected-but-not-archived) echo "  → Confirm release CI green, complete PRA/triage, then archive; do not call terminal" ;;
  release-pending) echo "  → Run δ release preflight/disconnect for batch $BATCH; keep receipt under unreleased" ;;
  post-merge-incomplete) echo "  → Complete role closeouts, exact marker, and release-batch assignment" ;;
  *) echo "  → Continue α/β review and merge lifecycle" ;;
esac

if [[ -n "$ARCHIVE_GAMMAS" && "$(grep -c . <<<"$ARCHIVE_GAMMAS" || true)" -gt 1 ]]; then
  echo "  ⚠️  Multiple archives found for cycle $CYCLE_NUM; terminal state is ambiguous"
fi
