#!/usr/bin/env bash
# cn-cdd-verify — verify CDD cycle artifact completeness against the canonical
# contract declared in src/packages/cnos.cdd/skills/cdd/CDD.md §5.3a (Artifact
# Location Matrix).
#
# Canonical paths (release-scoped triadic cycles):
#   PRA          docs/{tier}/{bundle}/{X.Y.Z}/POST-RELEASE-ASSESSMENT.md
#                CDD package default: docs/gamma/cdd/{X.Y.Z}/POST-RELEASE-ASSESSMENT.md
#   α close-out  .cdd/releases/{X.Y.Z}/alpha/CLOSE-OUT.md
#   β close-out  .cdd/releases/{X.Y.Z}/beta/CLOSE-OUT.md
#   γ close-out  .cdd/releases/{X.Y.Z}/gamma/CLOSE-OUT.md
#   tag          bare X.Y.Z (no v prefix)
#
# Legacy paths produce warnings, not pass conditions.
#
# Usage:
#   cn cdd-verify --version <ver>              release-scoped cycle (canonical contract)
#   cn cdd-verify --pr <number>                PR-scoped cycle (no release)
#   cn cdd-verify --version <ver> --triadic    also check canonical .cdd/ close-outs
#
# Optional:
#   --bundle <path>   override bundle-relative PRA dir (default: docs/gamma/cdd)
#   --repo-root <p>   override repo root detection (used for testing)
#
# Exit 0 if all required checks pass; non-zero on missing canonical artifacts.

set -euo pipefail

VERSION=""
PR=""
TRIADIC=false
BUNDLE_DIR="docs/gamma/cdd"
REPO_ROOT_OVERRIDE=""

usage() {
  cat >&2 <<EOF
Usage:
  cn cdd-verify --version <ver>              release-scoped cycle (canonical contract)
  cn cdd-verify --pr <number>                PR-scoped cycle (no release)
  cn cdd-verify --version <ver> --triadic    include canonical .cdd/ close-out checks

Options:
  --bundle <path>     bundle-relative PRA dir (default: docs/gamma/cdd)
  --repo-root <path>  override repo root (testing)

Canonical contract enforced (release-scoped):
  - bare git tag X.Y.Z exists
  - CHANGELOG contains the bare version
  - canonical PRA exists at <repo>/<bundle>/<X.Y.Z>/POST-RELEASE-ASSESSMENT.md
  - RELEASE.md present (warns if absent)

Triadic adds:
  - .cdd/releases/<X.Y.Z>/alpha/CLOSE-OUT.md
  - .cdd/releases/<X.Y.Z>/beta/CLOSE-OUT.md
  - .cdd/releases/<X.Y.Z>/gamma/CLOSE-OUT.md
  - .cdd/releases/<X.Y.Z>/gamma/KATA-VERDICT.md (warn-only)

Warnings (not failures):
  - v-prefixed tag exists (legacy)
  - legacy PRA at .cdd/releases/<X.Y.Z>/beta/{POST-RELEASE-ASSESSMENT,ASSESSMENT}.md
  - PR-comment close-out only (canonical close-out missing)
EOF
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --version) VERSION="$2"; shift 2 ;;
    --pr) PR="$2"; shift 2 ;;
    --triadic) TRIADIC=true; shift ;;
    --bundle) BUNDLE_DIR="$2"; shift 2 ;;
    --repo-root) REPO_ROOT_OVERRIDE="$2"; shift 2 ;;
    -h|--help) usage ;;
    *) echo "Unknown option: $1" >&2; usage ;;
  esac
done

if [[ -z "$VERSION" && -z "$PR" ]]; then
  echo "Error: must specify --version or --pr" >&2
  usage
fi

if [[ -n "$REPO_ROOT_OVERRIDE" ]]; then
  REPO_ROOT="$REPO_ROOT_OVERRIDE"
else
  REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || {
    echo "Error: not in a git repository" >&2
    exit 1
  }
fi

PASS=0
FAIL=0
WARN=0

check() {
  local label="$1"
  local result="$2"  # pass|fail|warn
  local detail="${3:-}"

  case "$result" in
    pass)
      PASS=$((PASS + 1))
      printf "  ✅ %s" "$label"
      ;;
    fail)
      FAIL=$((FAIL + 1))
      printf "  ❌ %s" "$label"
      ;;
    warn)
      WARN=$((WARN + 1))
      printf "  ⚠️  %s" "$label"
      ;;
  esac
  if [[ -n "$detail" ]]; then
    printf " — %s" "$detail"
  fi
  printf "\n"
}

# --- Core checks (always) ---

echo "## Core artifacts"

# PR check (best-effort; warn rather than fail when offline)
if [[ -n "$PR" ]]; then
  PR_NUM="$PR"
else
  PR_NUM=""
  if command -v gh &>/dev/null; then
    PR_NUM=$(gh pr list --state merged --search "$VERSION" --json number -q '.[0].number' 2>/dev/null || echo "")
  fi
fi

if [[ -n "$PR_NUM" ]]; then
  if command -v gh &>/dev/null; then
    PR_STATE=$(gh pr view "$PR_NUM" --json state -q '.state' 2>/dev/null || echo "UNKNOWN")
    if [[ "$PR_STATE" == "MERGED" ]]; then
      check "PR #${PR_NUM} merged" pass
    elif [[ "$PR_STATE" == "UNKNOWN" ]]; then
      check "PR #${PR_NUM} state" warn "could not query (gh auth?)"
    else
      check "PR #${PR_NUM} merged" fail "state: $PR_STATE"
    fi
  else
    check "PR #${PR_NUM} state" warn "gh CLI not available"
  fi
else
  check "PR identification" warn "could not determine PR number"
fi

# --- Release-scoped canonical checks ---

if [[ -n "$VERSION" ]]; then
  echo ""
  echo "## Release artifacts (${VERSION})"

  # CHANGELOG: bare version required
  if [[ -f "$REPO_ROOT/CHANGELOG.md" ]]; then
    if grep -q "$VERSION" "$REPO_ROOT/CHANGELOG.md"; then
      check "CHANGELOG entry (bare $VERSION)" pass
    else
      check "CHANGELOG entry (bare $VERSION)" fail "version $VERSION not found in CHANGELOG.md"
    fi
  else
    check "CHANGELOG entry" warn "no CHANGELOG.md found"
  fi

  # Git tag: bare X.Y.Z required; v-prefix is legacy and warns
  if git -C "$REPO_ROOT" tag -l "$VERSION" 2>/dev/null | grep -qx "$VERSION"; then
    check "Git tag (bare $VERSION)" pass
  else
    check "Git tag (bare $VERSION)" fail "canonical bare tag '$VERSION' not found"
  fi
  if git -C "$REPO_ROOT" tag -l "v$VERSION" 2>/dev/null | grep -qx "v$VERSION"; then
    check "Legacy v-prefixed tag" warn "v$VERSION exists; v-prefixed tags are legacy/noncanonical"
  fi

  # Canonical PRA path (CDD §5.3a)
  CANON_PRA="$REPO_ROOT/$BUNDLE_DIR/$VERSION/POST-RELEASE-ASSESSMENT.md"
  if [[ -f "$CANON_PRA" ]]; then
    check "Canonical PRA" pass "$BUNDLE_DIR/$VERSION/POST-RELEASE-ASSESSMENT.md"
  else
    check "Canonical PRA" fail "expected $BUNDLE_DIR/$VERSION/POST-RELEASE-ASSESSMENT.md"
  fi

  # Legacy PRA paths warn-only
  for legacy in \
    "$REPO_ROOT/.cdd/releases/$VERSION/beta/POST-RELEASE-ASSESSMENT.md" \
    "$REPO_ROOT/.cdd/releases/$VERSION/beta/ASSESSMENT.md"; do
    if [[ -f "$legacy" ]]; then
      check "Legacy PRA path" warn "${legacy#$REPO_ROOT/} present; canonical path is $BUNDLE_DIR/$VERSION/POST-RELEASE-ASSESSMENT.md"
    fi
  done

  # RELEASE.md (warn-only — release artifact may have been overwritten by next cycle)
  if [[ -f "$REPO_ROOT/RELEASE.md" ]]; then
    check "RELEASE.md present" pass
  else
    check "RELEASE.md present" warn "absent (may have been overwritten by next release)"
  fi
fi

# --- Triadic canonical close-out checks ---

if [[ "$TRIADIC" == true && -n "$VERSION" ]]; then
  echo ""
  echo "## Triadic close-outs (.cdd/releases/$VERSION/)"

  CDD_DIR="$REPO_ROOT/.cdd/releases/$VERSION"

  # Canonical α/β/γ close-outs are required per CDD §5.3a for release-scoped
  # triadic cycles. PR-comment close-outs are legacy and warn-only — they do
  # not satisfy the canonical contract.
  for role in alpha beta gamma; do
    canon="$CDD_DIR/$role/CLOSE-OUT.md"
    if [[ -f "$canon" ]]; then
      check "$role/CLOSE-OUT.md" pass
    else
      check "$role/CLOSE-OUT.md" fail "expected .cdd/releases/$VERSION/$role/CLOSE-OUT.md"
      # Note any legacy PR-comment evidence as an additional warning.
      if [[ "$role" != "gamma" && -n "$PR_NUM" ]] && command -v gh &>/dev/null; then
        legacy_pat="close-out\|closeout\|close out\|cycle.finding\|no.new.finding\|no findings"
        hits=$(gh pr view "$PR_NUM" --json comments -q '.comments[].body' 2>/dev/null | grep -ci "$legacy_pat" || true)
        hits="${hits:-0}"
        if [[ "$hits" -gt 0 ]]; then
          check "$role legacy PR-comment close-out" warn "PR-comment close-out present; canonical path is required for release-scoped triadic cycles"
        fi
      fi
    fi
  done

  if [[ -f "$CDD_DIR/gamma/KATA-VERDICT.md" ]]; then
    check "γ KATA-VERDICT.md" pass
  else
    check "γ KATA-VERDICT.md" warn "not found (kata may not have run)"
  fi
fi

# --- Summary ---

echo ""
TOTAL=$((PASS + FAIL + WARN))
echo "## Summary: $PASS passed, $FAIL failed, $WARN warnings (${TOTAL} total)"

if [[ $FAIL -gt 0 ]]; then
  echo ""
  echo "❌ Cycle artifact verification FAILED"
  exit 1
elif [[ $WARN -gt 0 ]]; then
  echo ""
  echo "⚠️  Cycle artifact verification PASSED with warnings"
  exit 0
else
  echo ""
  echo "✅ Cycle artifact verification PASSED"
  exit 0
fi
