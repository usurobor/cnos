#!/usr/bin/env bash
# cn-cdd-verify — verify CDD cycle artifact completeness against the canonical
# contract declared in src/packages/cnos.cdd/skills/cdd/CDD.md §5.3a (Artifact
# Location Matrix).
#
# Canonical paths (release-scoped triadic cycles):
#   PRA          docs/{tier}/{bundle}/{X.Y.Z}/POST-RELEASE-ASSESSMENT.md
#                CDD package default: docs/gamma/cdd/{X.Y.Z}/POST-RELEASE-ASSESSMENT.md
#   α close-out  .cdd/releases/{X.Y.Z}/alpha/CLOSE-OUT.md (legacy)
#   β close-out  .cdd/releases/{X.Y.Z}/beta/CLOSE-OUT.md (legacy)
#   γ close-out  .cdd/releases/{X.Y.Z}/gamma/CLOSE-OUT.md (legacy)
#   tag          bare X.Y.Z (no v prefix)
#
# Current cycle-scoped paths (post-#283):
#   Cycle dir    .cdd/releases/{X.Y.Z}/{N}/
#   5 hard-gate  self-coherence.md, beta-review.md, alpha-closeout.md,
#                beta-closeout.md, gamma-closeout.md
#   Optional     gamma-clarification.md
#
# Legacy paths produce warnings, not pass conditions.
#
# Usage:
#   cn cdd-verify --version <ver>              release-scoped cycle (canonical contract)
#   cn cdd-verify --pr <number>                PR-scoped cycle (no release)
#   cn cdd-verify --version <ver> --triadic    also check legacy .cdd/ close-outs
#   cn cdd-verify --version <ver> --cycle <N>  check current cycle-scoped artifacts
#   cn cdd-verify --all                        repository-wide ledger check (unreleased + released)
#   cn cdd-verify --unreleased                 check only .cdd/unreleased/ directories
#
# Optional:
#   --bundle <path>      override bundle-relative PRA dir (default: docs/gamma/cdd)
#   --repo-root <p>      override repo root detection (used for testing)
#   --exceptions <path>  legacy exceptions file (YAML format)
#
# Exit 0 if all required checks pass; non-zero on missing canonical artifacts.

set -euo pipefail

VERSION=""
PR=""
CYCLE=""
TRIADIC=false
ALL_MODE=false
UNRELEASED_ONLY=false
BUNDLE_DIR="docs/gamma/cdd"
REPO_ROOT_OVERRIDE=""
EXCEPTIONS_FILE=""

usage() {
  cat >&2 <<EOF
Usage:
  cn cdd-verify --version <ver>              release-scoped cycle (canonical contract)
  cn cdd-verify --pr <number>                PR-scoped cycle (no release)
  cn cdd-verify --version <ver> --triadic    include legacy .cdd/ close-out checks
  cn cdd-verify --version <ver> --cycle <N>  check current cycle-scoped artifacts
  cn cdd-verify --all                        repository-wide ledger check (unreleased + released)
  cn cdd-verify --unreleased                 check only .cdd/unreleased/ directories

Options:
  --bundle <path>        bundle-relative PRA dir (default: docs/gamma/cdd)
  --repo-root <path>     override repo root (testing)
  --exceptions <path>    legacy exceptions file (YAML format)

Canonical contract enforced (release-scoped):
  - bare git tag X.Y.Z exists
  - CHANGELOG contains the bare version
  - canonical PRA exists at <repo>/<bundle>/<X.Y.Z>/POST-RELEASE-ASSESSMENT.md
  - RELEASE.md present (warns if absent)

Cycle mode (--cycle <N>) validates current artifact layout:
  - .cdd/releases/<X.Y.Z>/<N>/self-coherence.md
  - .cdd/releases/<X.Y.Z>/<N>/beta-review.md
  - .cdd/releases/<X.Y.Z>/<N>/alpha-closeout.md
  - .cdd/releases/<X.Y.Z>/<N>/beta-closeout.md
  - .cdd/releases/<X.Y.Z>/<N>/gamma-closeout.md
  - Required sections within each artifact (per role SKILL.md)
  - Warns on orphaned .cdd/unreleased/<N>/ directories

Repository-wide modes:
  --all: validates both .cdd/unreleased/ and .cdd/releases/ directories
    - Scans all issue directories for artifact completeness
    - Classifies cycles as triadic or small-change
    - Validates required artifacts per cycle type
    - Reports summary across all found cycles

  --unreleased: validates only .cdd/unreleased/ directories
    - Useful for checking active/unmerged cycles
    - Same classification and validation as --all mode
    - Faster than --all when only checking current work

Triadic (legacy) checks:
  - .cdd/releases/<X.Y.Z>/alpha/CLOSE-OUT.md
  - .cdd/releases/<X.Y.Z>/beta/CLOSE-OUT.md
  - .cdd/releases/<X.Y.Z>/gamma/CLOSE-OUT.md
  - .cdd/releases/<X.Y.Z>/gamma/KATA-VERDICT.md (warn-only)

Examples:
  # Check current repo CDD artifact ledger (most common)
  cn cdd-verify --all

  # Check only active unreleased cycles
  cn cdd-verify --unreleased

  # Check specific release with cycle details
  cn cdd-verify --version 3.74.0 --cycle 286

  # Use exception file for known historical gaps
  cn cdd-verify --all --exceptions .cdd/exceptions.yml

What is validated:
  - Artifact presence per CDD.md §5.3a Artifact Location Matrix
  - Basic required sections in each artifact (Gap, Skills, ACs, CDD Trace)
  - Cycle type classification (triadic vs small-change)
  - Exception-backed missing artifacts (warns instead of fails)

What is NOT validated:
  - Semantic truth of artifact contents
  - Cross-artifact consistency (e.g., ACs match between issue and self-coherence)
  - Release note freshness (unless implemented separately)

Warnings (not failures):
  - v-prefixed tag exists (legacy)
  - legacy PRA at .cdd/releases/<X.Y.Z>/beta/{POST-RELEASE-ASSESSMENT,ASSESSMENT}.md
  - PR-comment close-out only (canonical close-out missing)
  - Missing artifacts that are exception-backed
EOF
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --version) VERSION="$2"; shift 2 ;;
    --pr) PR="$2"; shift 2 ;;
    --cycle) CYCLE="$2"; shift 2 ;;
    --triadic) TRIADIC=true; shift ;;
    --all) ALL_MODE=true; shift ;;
    --unreleased) UNRELEASED_ONLY=true; shift ;;
    --bundle) BUNDLE_DIR="$2"; shift 2 ;;
    --repo-root) REPO_ROOT_OVERRIDE="$2"; shift 2 ;;
    --exceptions) EXCEPTIONS_FILE="$2"; shift 2 ;;
    -h|--help) usage ;;
    *) echo "Unknown option: $1" >&2; usage ;;
  esac
done

if [[ -n "$CYCLE" && -z "$VERSION" ]]; then
  echo "Error: --cycle requires --version" >&2
  usage
fi

# New validation for all/unreleased modes
if [[ "$ALL_MODE" == true && ( -n "$VERSION" || -n "$PR" || -n "$CYCLE" || "$TRIADIC" == true ) ]]; then
  echo "Error: --all cannot be combined with other modes" >&2
  usage
fi

if [[ "$UNRELEASED_ONLY" == true && ( -n "$VERSION" || -n "$PR" || -n "$CYCLE" || "$TRIADIC" == true ) ]]; then
  echo "Error: --unreleased cannot be combined with other modes" >&2
  usage
fi

if [[ "$ALL_MODE" == false && "$UNRELEASED_ONLY" == false && -z "$VERSION" && -z "$PR" ]]; then
  echo "Error: must specify --version, --pr, --all, or --unreleased" >&2
  usage
fi

if [[ -n "$REPO_ROOT_OVERRIDE" ]]; then
  REPO_ROOT="$REPO_ROOT_OVERRIDE"
else
  REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || {
    echo "Error: not in a git repository" >&2
    exit 1
  }
fi

PASS=0
FAIL=0
WARN=0

# Legacy exceptions tracking (declare globally)
declare -A EXCEPTIONS_LOADED

check() {
  local label="$1"
  local result="$2"  # pass|fail|warn
  local detail="${3:-}"

  case "$result" in
    pass)
      PASS=$((PASS + 1))
      printf "  ✅ %s" "$label"
      ;;
    fail)
      FAIL=$((FAIL + 1))
      printf "  ❌ %s" "$label"
      ;;
    warn)
      WARN=$((WARN + 1))
      printf "  ⚠️  %s" "$label"
      ;;
  esac
  if [[ -n "$detail" ]]; then
    printf " — %s" "$detail"
  fi
  printf "\n"
}

load_exceptions() {
  if [[ -n "$EXCEPTIONS_FILE" && -f "$EXCEPTIONS_FILE" ]]; then
    echo "Loading legacy exceptions from: $EXCEPTIONS_FILE"

    # Simple YAML parsing for our exception format
    # Expected format:
    # exceptions:
    #   - path: ".cdd/unreleased/286/alpha-closeout.md"
    #     missing_artifacts: ["alpha-closeout.md"]
    #     reason: "historical cycle predating close-out requirement"
    #     repair_possible: false
    #     follow_up: "none"

    while IFS= read -r line; do
      # Extract path from YAML lines like "  - path: \".cdd/unreleased/286/alpha-closeout.md\""
      # Handle both quoted and unquoted paths
      if [[ "$line" =~ ^[[:space:]]*-?[[:space:]]*path:[[:space:]]*\"(.*)\"[[:space:]]*$ ]]; then
        local path="${BASH_REMATCH[1]}"
        EXCEPTIONS_LOADED["$path"]=true
      elif [[ "$line" =~ ^[[:space:]]*-?[[:space:]]*path:[[:space:]]*([^[:space:]].*)$ ]]; then
        local path="${BASH_REMATCH[1]}"
        EXCEPTIONS_LOADED["$path"]=true
      fi
    done < "$EXCEPTIONS_FILE"

    # Count exceptions (handle unbound variable temporarily)
    set +u
    local count=${#EXCEPTIONS_LOADED[@]}
    set -u
    if [[ $count -gt 0 ]]; then
      echo "Loaded $count exception paths"
    else
      echo "No exception paths found in file"
    fi
  fi
}

is_exception_backed() {
  local path="$1"
  # Check if EXCEPTIONS_LOADED has been initialized and contains the path
  [[ ${EXCEPTIONS_LOADED[$path]+_} ]]
}

is_legacy_version() {
  local version="$1"
  # Returns 0 (true) if version is before v3.65.0 (epoch threshold)
  # Legacy cycles get warnings instead of failures for missing artifacts

  # Handle non-standard version directories
  if [[ ! "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    return 1  # Non-semver versions are not legacy (conservative approach)
  fi

  # Parse version components
  local major minor patch
  IFS='.' read -r major minor patch <<< "$version"

  # Compare against 3.74.0 (treat earlier versions as transitional/legacy)
  # Based on CI failures, full artifact enforcement seems to start around v3.74.0+
  if [[ $major -lt 3 ]]; then
    return 0  # Before v3.x.x
  elif [[ $major -eq 3 && $minor -lt 74 ]]; then
    return 0  # Before v3.74.x (transitional period for artifact enforcement)
  else
    return 1  # v3.74.0 or later
  fi
}

classify_cycle_type() {
  local cycle_dir="$1"
  # Classify cycle as triadic/substantial or small-change based on artifact presence
  # Returns: "triadic", "small-change", or "unknown"

  local required_triadic=(
    "self-coherence.md"
    "beta-review.md"
    "alpha-closeout.md"
    "beta-closeout.md"
    "gamma-closeout.md"
  )

  local triadic_count=0
  for artifact in "${required_triadic[@]}"; do
    if [[ -f "$cycle_dir/$artifact" ]]; then
      triadic_count=$((triadic_count + 1))
    fi
  done

  # If we have all 5 triadic artifacts, classify as triadic
  if [[ $triadic_count -eq 5 ]]; then
    echo "triadic"
    return
  fi

  # Check for small-change indicators
  # Small-change cycles may have only self-coherence.md and alpha-closeout.md
  # (beta-closeout.md and gamma-closeout.md are "not applicable" per CDD.md §1.2)
  if [[ -f "$cycle_dir/self-coherence.md" || -f "$cycle_dir/alpha-closeout.md" ]]; then
    # Further check: if beta-review.md exists, this is likely triadic
    if [[ -f "$cycle_dir/beta-review.md" ]]; then
      echo "triadic"  # Has review artifact = triadic
    else
      echo "small-change"
    fi
  else
    echo "unknown"
  fi
}

check_unreleased_cycle() {
  local issue_num="$1"
  local cycle_dir="$REPO_ROOT/.cdd/unreleased/$issue_num"

  if [[ ! -d "$cycle_dir" ]]; then
    check "Issue #$issue_num directory" fail ".cdd/unreleased/$issue_num not found"
    return
  fi

  local cycle_type
  cycle_type=$(classify_cycle_type "$cycle_dir")

  case "$cycle_type" in
    "triadic")
      echo "  Checking triadic cycle #$issue_num"
      check_unreleased_triadic_artifacts "$cycle_dir" "$issue_num"
      ;;
    "small-change")
      echo "  Checking small-change cycle #$issue_num"
      check_small_change_artifacts "$cycle_dir" "$issue_num"
      ;;
    "unknown")
      check "Issue #$issue_num classification" warn "cannot determine cycle type - no recognizable artifacts"
      ;;
  esac
}

check_triadic_artifacts() {
  local cycle_dir="$1"
  local issue_num="$2"
  local version="${3:-}"  # Optional version for legacy handling

  local required_triadic=(
    "self-coherence.md"
    "beta-review.md"
    "alpha-closeout.md"
    "beta-closeout.md"
    "gamma-closeout.md"
  )

  # Determine if this is a legacy version
  local is_legacy=false
  if [[ -n "$version" ]] && is_legacy_version "$version"; then
    is_legacy=true
  fi

  for artifact in "${required_triadic[@]}"; do
    local artifact_path="$cycle_dir/$artifact"
    if [[ -f "$artifact_path" ]]; then
      check "$artifact (issue #$issue_num)" pass
      validate_artifact_sections "$artifact_path" "$artifact" "$version"
    else
      # Build the correct exception path based on whether this is unreleased or released
      local exception_path
      if [[ -n "$version" ]]; then
        # For released cycles, use releases path format
        exception_path=".cdd/releases/$version/$(basename "$cycle_dir")/$artifact"
      else
        # For unreleased cycles, use unreleased path format
        local issue_num_only=$(echo "$issue_num" | sed 's/ .*//')  # Remove version suffix if present
        exception_path=".cdd/unreleased/$issue_num_only/$artifact"
      fi

      if is_exception_backed "$exception_path"; then
        check "$artifact (issue #$issue_num)" warn "missing but exception-backed: $exception_path"
      elif [[ "$is_legacy" == true ]]; then
        check "$artifact (issue #$issue_num)" warn "missing in legacy cycle (pre-v3.65.0) — expected .cdd/unreleased/$issue_num/$artifact"
      else
        check "$artifact (issue #$issue_num)" fail "expected .cdd/unreleased/$issue_num/$artifact"
      fi
    fi
  done
}

check_unreleased_triadic_artifacts() {
  local cycle_dir="$1"
  local issue_num="$2"

  # For unreleased cycles, use graduated enforcement:
  # - self-coherence.md and beta-review.md should exist (they drive the cycle)
  # - close-outs should NOT exist (warn if missing, they're written post-merge)
  # - section validation is more lenient for in-progress cycles

  local core_artifacts=("self-coherence.md" "beta-review.md")
  local closeout_artifacts=("alpha-closeout.md" "beta-closeout.md" "gamma-closeout.md")

  # Check core artifacts (should exist for active cycles)
  for artifact in "${core_artifacts[@]}"; do
    local artifact_path="$cycle_dir/$artifact"
    if [[ -f "$artifact_path" ]]; then
      check "$artifact (issue #$issue_num)" pass
      validate_unreleased_artifact_sections "$artifact_path" "$artifact"
    else
      local exception_path=".cdd/unreleased/$issue_num/$artifact"
      if is_exception_backed "$exception_path"; then
        check "$artifact (issue #$issue_num)" warn "missing but exception-backed: $exception_path"
      else
        check "$artifact (issue #$issue_num)" fail "expected .cdd/unreleased/$issue_num/$artifact"
      fi
    fi
  done

  # Check close-out artifacts (should NOT exist for unreleased cycles)
  for artifact in "${closeout_artifacts[@]}"; do
    local artifact_path="$cycle_dir/$artifact"
    if [[ -f "$artifact_path" ]]; then
      check "$artifact (issue #$issue_num)" warn "present in unreleased cycle - may indicate stale cycle"
      validate_artifact_sections "$artifact_path" "$artifact"  # No version, use standard validation
    else
      # Missing close-outs are expected for unreleased cycles
      check "$artifact (issue #$issue_num)" warn "missing in unreleased cycle (expected until cycle complete)"
    fi
  done
}

check_small_change_artifacts() {
  local cycle_dir="$1"
  local issue_num="$2"

  # Small-change cycles: self-coherence.md and alpha-closeout.md optional
  # beta-review.md, beta-closeout.md, gamma-closeout.md not applicable

  if [[ -f "$cycle_dir/self-coherence.md" ]]; then
    check "self-coherence.md (small-change #$issue_num)" pass
    validate_artifact_sections "$cycle_dir/self-coherence.md" "self-coherence.md"
  else
    check "self-coherence.md (small-change #$issue_num)" warn "optional for small-change cycles"
  fi

  if [[ -f "$cycle_dir/alpha-closeout.md" ]]; then
    check "alpha-closeout.md (small-change #$issue_num)" pass
    validate_artifact_sections "$cycle_dir/alpha-closeout.md" "alpha-closeout.md"
  else
    check "alpha-closeout.md (small-change #$issue_num)" warn "optional for small-change cycles"
  fi

  # These should NOT be present in small-change cycles
  for artifact in "beta-review.md" "beta-closeout.md" "gamma-closeout.md"; do
    if [[ -f "$cycle_dir/$artifact" ]]; then
      check "$artifact (small-change #$issue_num)" warn "unexpected in small-change cycle - may be misclassified"
    fi
  done
}

validate_artifact_sections() {
  local artifact_path="$1"
  local artifact_name="$2"
  local version="${3:-}"  # Optional version for legacy handling

  # Determine if this is a legacy version
  local is_legacy=false
  if [[ -n "$version" ]] && is_legacy_version "$version"; then
    is_legacy=true
  fi

  # Basic section validation - check for key sections based on artifact type
  case "$artifact_name" in
    "self-coherence.md")
      # Required sections: Gap, Mode/Skills, ACs/AC Coverage, Self-check, Debt, CDD-Trace
      missing_sections=()

      if ! grep -q "^## Gap" "$artifact_path" 2>/dev/null; then
        missing_sections+=("Gap")
      fi

      if ! grep -q "^## \(Skills\|Mode\)" "$artifact_path" 2>/dev/null; then
        missing_sections+=("Skills/Mode")
      fi

      if ! grep -q "^## \(ACs\|AC Coverage\)" "$artifact_path" 2>/dev/null; then
        missing_sections+=("ACs/AC Coverage")
      fi

      if ! grep -q "^## CDD Trace" "$artifact_path" 2>/dev/null; then
        missing_sections+=("CDD Trace")
      fi

      if ! grep -qi "^## .*\(self-check\|debt\)" "$artifact_path" 2>/dev/null; then
        missing_sections+=("Self-check or Debt")
      fi

      if [[ ${#missing_sections[@]} -gt 0 ]]; then
        # Check if this self-coherence.md file is exception-backed for missing sections
        local sections_exception_path="$artifact_path"
        if is_exception_backed "$sections_exception_path"; then
          check "$artifact_name sections" warn "missing required sections but exception-backed: ${missing_sections[*]}"
        elif [[ "$is_legacy" == true ]]; then
          check "$artifact_name sections" warn "missing required sections in legacy cycle (pre-v3.65.0): ${missing_sections[*]}"
        else
          check "$artifact_name sections" fail "missing required sections: ${missing_sections[*]}"
        fi
        return 0
      fi
      ;;
    "beta-review.md")
      # Check for review-related content (verdict, findings)
      if ! grep -qi "verdict\|review\|findings\|RC\|approved" "$artifact_path" 2>/dev/null; then
        check "$artifact_name sections" warn "may be missing review verdict/findings (basic check)"
        return 0
      fi
      ;;
    "alpha-closeout.md"|"beta-closeout.md"|"gamma-closeout.md")
      # Basic check for close-out structure
      if ! grep -qi "summary\|findings\|cycle\|close.*out" "$artifact_path" 2>/dev/null; then
        check "$artifact_name sections" warn "may be missing close-out structure (basic check)"
        return 0
      fi
      ;;
    *)
      return 0  # Unknown artifact type, skip validation
      ;;
  esac

  check "$artifact_name sections" pass "basic section validation passed"
}

validate_unreleased_artifact_sections() {
  local artifact_path="$1"
  local artifact_name="$2"

  # More lenient section validation for unreleased (in-progress) cycles
  case "$artifact_name" in
    "self-coherence.md")
      # For unreleased cycles, we're more forgiving of incomplete sections
      # since the cycle may be in progress or from before current standards
      missing_sections=()
      has_any_structure=false

      # Check for any sign of structured content
      if grep -q "^## " "$artifact_path" 2>/dev/null; then
        has_any_structure=true
      fi

      if [[ "$has_any_structure" == false ]]; then
        check "$artifact_name sections" warn "unreleased cycle with minimal structure (may be in-progress)"
        return 0
      fi

      # Check for core sections, but warn instead of fail for missing ones
      if ! grep -q "^## Gap" "$artifact_path" 2>/dev/null; then
        missing_sections+=("Gap")
      fi

      if ! grep -q "^## \(Skills\|Mode\)" "$artifact_path" 2>/dev/null; then
        missing_sections+=("Skills/Mode")
      fi

      if ! grep -q "^## \(ACs\|AC Coverage\)" "$artifact_path" 2>/dev/null; then
        missing_sections+=("ACs/AC Coverage")
      fi

      if ! grep -q "^## CDD Trace" "$artifact_path" 2>/dev/null; then
        missing_sections+=("CDD Trace")
      fi

      if [[ ${#missing_sections[@]} -gt 0 ]]; then
        check "$artifact_name sections" warn "missing sections in unreleased cycle (may be in-progress): ${missing_sections[*]}"
        return 0
      fi
      ;;
    "beta-review.md")
      # Check for review-related content (verdict, findings)
      if ! grep -qi "verdict\|review\|findings\|RC\|approved" "$artifact_path" 2>/dev/null; then
        check "$artifact_name sections" warn "may be missing review verdict/findings (basic check)"
        return 0
      fi
      ;;
    *)
      # Use standard validation for other artifact types
      validate_artifact_sections "$artifact_path" "$artifact_name"
      return $?
      ;;
  esac

  check "$artifact_name sections" pass "basic section validation passed"
}

# --- Core checks (always) ---

# Load exceptions if provided
load_exceptions

echo "## Core artifacts"

# PR check (best-effort; warn rather than fail when offline)
if [[ -n "$PR" ]]; then
  PR_NUM="$PR"
else
  PR_NUM=""
  if command -v gh &>/dev/null; then
    PR_NUM=$(gh pr list --state merged --search "$VERSION" --json number -q '.[0].number' 2>/dev/null || echo "")
  fi
fi

if [[ -n "$PR_NUM" ]]; then
  if command -v gh &>/dev/null; then
    PR_STATE=$(gh pr view "$PR_NUM" --json state -q '.state' 2>/dev/null || echo "UNKNOWN")
    if [[ "$PR_STATE" == "MERGED" ]]; then
      check "PR #${PR_NUM} merged" pass
    elif [[ "$PR_STATE" == "UNKNOWN" ]]; then
      check "PR #${PR_NUM} state" warn "could not query (gh auth?)"
    else
      check "PR #${PR_NUM} merged" fail "state: $PR_STATE"
    fi
  else
    check "PR #${PR_NUM} state" warn "gh CLI not available"
  fi
else
  check "PR identification" warn "could not determine PR number"
fi

# --- Release-scoped canonical checks ---

if [[ -n "$VERSION" ]]; then
  echo ""
  echo "## Release artifacts (${VERSION})"

  # CHANGELOG: bare version required
  if [[ -f "$REPO_ROOT/CHANGELOG.md" ]]; then
    if grep -q "$VERSION" "$REPO_ROOT/CHANGELOG.md"; then
      check "CHANGELOG entry (bare $VERSION)" pass
    else
      check "CHANGELOG entry (bare $VERSION)" fail "version $VERSION not found in CHANGELOG.md"
    fi
  else
    check "CHANGELOG entry" warn "no CHANGELOG.md found"
  fi

  # Git tag: bare X.Y.Z required; v-prefix is legacy and warns
  if git -C "$REPO_ROOT" tag -l "$VERSION" 2>/dev/null | grep -qx "$VERSION"; then
    check "Git tag (bare $VERSION)" pass
  else
    check "Git tag (bare $VERSION)" fail "canonical bare tag '$VERSION' not found"
  fi
  if git -C "$REPO_ROOT" tag -l "v$VERSION" 2>/dev/null | grep -qx "v$VERSION"; then
    check "Legacy v-prefixed tag" warn "v$VERSION exists; v-prefixed tags are legacy/noncanonical"
  fi

  # Canonical PRA path (CDD §5.3a)
  CANON_PRA="$REPO_ROOT/$BUNDLE_DIR/$VERSION/POST-RELEASE-ASSESSMENT.md"
  if [[ -f "$CANON_PRA" ]]; then
    check "Canonical PRA" pass "$BUNDLE_DIR/$VERSION/POST-RELEASE-ASSESSMENT.md"
  else
    check "Canonical PRA" fail "expected $BUNDLE_DIR/$VERSION/POST-RELEASE-ASSESSMENT.md"
  fi

  # Legacy PRA paths warn-only
  for legacy in \
    "$REPO_ROOT/.cdd/releases/$VERSION/beta/POST-RELEASE-ASSESSMENT.md" \
    "$REPO_ROOT/.cdd/releases/$VERSION/beta/ASSESSMENT.md"; do
    if [[ -f "$legacy" ]]; then
      check "Legacy PRA path" warn "${legacy#$REPO_ROOT/} present; canonical path is $BUNDLE_DIR/$VERSION/POST-RELEASE-ASSESSMENT.md"
    fi
  done

  # RELEASE.md (warn-only — release artifact may have been overwritten by next cycle)
  if [[ -f "$REPO_ROOT/RELEASE.md" ]]; then
    check "RELEASE.md present" pass
  else
    check "RELEASE.md present" warn "absent (may have been overwritten by next release)"
  fi
fi

# --- Triadic canonical close-out checks ---

if [[ "$TRIADIC" == true && -n "$VERSION" ]]; then
  echo ""
  echo "## Triadic close-outs (.cdd/releases/$VERSION/)"

  CDD_DIR="$REPO_ROOT/.cdd/releases/$VERSION"

  # Canonical α/β/γ close-outs are required per CDD §5.3a for release-scoped
  # triadic cycles. PR-comment close-outs are legacy and warn-only — they do
  # not satisfy the canonical contract.
  for role in alpha beta gamma; do
    canon="$CDD_DIR/$role/CLOSE-OUT.md"
    if [[ -f "$canon" ]]; then
      check "$role/CLOSE-OUT.md" pass
    else
      check "$role/CLOSE-OUT.md" fail "expected .cdd/releases/$VERSION/$role/CLOSE-OUT.md"
      # Note any legacy PR-comment evidence as an additional warning.
      if [[ "$role" != "gamma" && -n "$PR_NUM" ]] && command -v gh &>/dev/null; then
        legacy_pat="close-out\|closeout\|close out\|cycle.finding\|no.new.finding\|no findings"
        hits=$(gh pr view "$PR_NUM" --json comments -q '.comments[].body' 2>/dev/null | grep -ci "$legacy_pat" || true)
        hits="${hits:-0}"
        if [[ "$hits" -gt 0 ]]; then
          check "$role legacy PR-comment close-out" warn "PR-comment close-out present; canonical path is required for release-scoped triadic cycles"
        fi
      fi
    fi
  done

  if [[ -f "$CDD_DIR/gamma/KATA-VERDICT.md" ]]; then
    check "γ KATA-VERDICT.md" pass
  else
    check "γ KATA-VERDICT.md" warn "not found (kata may not have run)"
  fi
fi

# --- Cycle-scoped canonical artifact checks ---

if [[ -n "$CYCLE" && -n "$VERSION" ]]; then
  echo ""
  echo "## Cycle-scoped artifacts (.cdd/releases/$VERSION/$CYCLE/)"

  CYCLE_DIR="$REPO_ROOT/.cdd/releases/$VERSION/$CYCLE"

  # 5 hard-gate artifacts required per CDD §5.3a for current cycle-scoped layout
  hardgate_files=(
    "self-coherence.md"
    "beta-review.md"
    "alpha-closeout.md"
    "beta-closeout.md"
    "gamma-closeout.md"
  )

  for artifact in "${hardgate_files[@]}"; do
    artifact_path="$CYCLE_DIR/$artifact"
    if [[ -f "$artifact_path" ]]; then
      check "$artifact" pass
      # Basic section validation for each artifact
      validate_artifact_sections "$artifact_path" "$artifact"
    else
      check "$artifact" fail "expected .cdd/releases/$VERSION/$CYCLE/$artifact"
    fi
  done

  # Optional artifacts (warn if missing expected ones based on cycle type)
  optional_artifacts=(
    "gamma-clarification.md"
  )

  for optional in "${optional_artifacts[@]}"; do
    optional_path="$CYCLE_DIR/$optional"
    if [[ -f "$optional_path" ]]; then
      check "$optional (optional)" pass
    fi
  done

  # Warn on orphaned .cdd/unreleased/{N}/ directories on main branch
  if git -C "$REPO_ROOT" branch --show-current 2>/dev/null | grep -q '^main$'; then
    if [[ -d "$REPO_ROOT/.cdd/unreleased" ]]; then
      orphaned=$(find "$REPO_ROOT/.cdd/unreleased" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)
      if [[ "$orphaned" -gt 0 ]]; then
        orphan_list=$(find "$REPO_ROOT/.cdd/unreleased" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | xargs -I {} basename {} | tr '\n' ' ')
        check "Orphaned unreleased directories" warn "found $orphaned directories: $orphan_list"
      else
        check "No orphaned unreleased directories" pass
      fi
    else
      check "No orphaned unreleased directories" pass "no .cdd/unreleased directory"
    fi
  fi
fi

# --- Repository-wide ledger checks (--all and --unreleased modes) ---

if [[ "$ALL_MODE" == true || "$UNRELEASED_ONLY" == true ]]; then
  echo ""
  echo "## Unreleased cycles (.cdd/unreleased/)"

  if [[ -d "$REPO_ROOT/.cdd/unreleased" ]]; then
    unreleased_dirs=$(find "$REPO_ROOT/.cdd/unreleased" -mindepth 1 -maxdepth 1 -type d 2>/dev/null || true)
    if [[ -n "$unreleased_dirs" ]]; then
      issue_count=0
      while IFS= read -r dir; do
        issue_num=$(basename "$dir")
        if [[ "$issue_num" =~ ^[0-9]+$ ]]; then
          check_unreleased_cycle "$issue_num"
          issue_count=$((issue_count + 1))
        else
          check "Invalid unreleased directory" warn "non-numeric directory name: $issue_num"
        fi
      done <<< "$unreleased_dirs"

      if [[ $issue_count -eq 0 ]]; then
        check "Unreleased cycles" warn "no valid issue directories found in .cdd/unreleased/"
      else
        check "Unreleased cycles scanned" pass "$issue_count issue directories checked"
      fi
    else
      check "Unreleased cycles" pass "no unreleased cycles (.cdd/unreleased/ is empty)"
    fi
  else
    check "Unreleased cycles" pass "no .cdd/unreleased/ directory"
  fi
fi

if [[ "$ALL_MODE" == true ]]; then
  echo ""
  echo "## Released cycles (.cdd/releases/)"

  if [[ -d "$REPO_ROOT/.cdd/releases" ]]; then
    # Check all version directories
    version_dirs=$(find "$REPO_ROOT/.cdd/releases" -mindepth 1 -maxdepth 1 -type d 2>/dev/null || true)
    if [[ -n "$version_dirs" ]]; then
      version_count=0
      total_cycles=0
      while IFS= read -r version_dir; do
        version=$(basename "$version_dir")
        echo "  Checking version $version"

        # Find all cycle directories within this version
        cycle_dirs=$(find "$version_dir" -mindepth 1 -maxdepth 1 -type d 2>/dev/null || true)
        if [[ -n "$cycle_dirs" ]]; then
          cycle_count=0
          while IFS= read -r cycle_dir; do
            issue_num=$(basename "$cycle_dir")
            if [[ "$issue_num" =~ ^[0-9]+$ ]]; then
              echo "    Issue #$issue_num"
              check_triadic_artifacts "$cycle_dir" "$issue_num (v$version)" "$version"
              cycle_count=$((cycle_count + 1))
              total_cycles=$((total_cycles + 1))
            else
              check "Invalid cycle directory" warn "non-numeric directory in $version: $issue_num"
            fi
          done <<< "$cycle_dirs"

          check "Version $version cycles" pass "$cycle_count cycles found"
        else
          check "Version $version cycles" warn "no cycle directories found"
        fi

        version_count=$((version_count + 1))
      done <<< "$version_dirs"

      check "Released versions scanned" pass "$version_count versions, $total_cycles total cycles"
    else
      check "Released cycles" pass "no released versions (.cdd/releases/ is empty)"
    fi
  else
    check "Released cycles" pass "no .cdd/releases/ directory"
  fi
fi

# --- Summary ---

echo ""
TOTAL=$((PASS + FAIL + WARN))
echo "## Summary: $PASS passed, $FAIL failed, $WARN warnings (${TOTAL} total)"

if [[ $FAIL -gt 0 ]]; then
  echo ""
  echo "❌ Cycle artifact verification FAILED"
  exit 1
elif [[ $WARN -gt 0 ]]; then
  echo ""
  echo "⚠️  Cycle artifact verification PASSED with warnings"
  exit 0
else
  echo ""
  echo "✅ Cycle artifact verification PASSED"
  exit 0
fi
