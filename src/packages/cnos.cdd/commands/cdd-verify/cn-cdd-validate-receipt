#!/usr/bin/env python3
"""
cn-cdd-validate-receipt — V (Contract × Receipt → ValidationVerdict).

Implementation of V per the design frozen in #367's RECEIPT-VALIDATION.md and
the V signature canonicalized in #370's COHERENCE-CELL-NORMAL-FORM.md:

    V : Contract × Receipt → ValidationVerdict

V dispatches on `protocol_id` declared in the receipt frontmatter (per #388's
three-package schema split) and validates against the protocol's CUE schema
package, then dereferences `evidence_refs.*` paths bound into the receipt
(per the essay §3 "Let V wrap CUE and evidence checks"), then applies
counterfeit-receipt rules (per #389 AC8).

V does NOT inspect raw evidence outside the receipt's bound refs; δ does not
re-dereference. The verdict is the parent-facing trust surface.

Invoked by the operator-facing wrapper `cn-cdd-verify --receipt <path>`.
Direct invocation: `cn-cdd-validate-receipt <receipt.yaml> [--contract C]
[--json] [--repo-root R]`.

Exit codes:
    0  result: PASS
    1  result: FAIL
    2  V itself errored (parse fail, missing schema package, cue missing, ...)
"""

import argparse
import datetime
import json
import os
import subprocess
import sys
from pathlib import Path

V_IDENTITY = "cnos.cdd.validate_receipt"
V_VERSION = "phase3.0"

# Dispatch table: protocol_id → (schema-package dir, CUE definition, extra schema files).
# Schema-package dir is repo-relative. Extra schema files for cdd-generic
# include the contract + boundary_decision (cue needs all definitions resolvable
# in the same package context).
DISPATCH = {
    "cnos.cdd.generic.receipt.v1": {
        "definition": "#Receipt",
        "schema_files": [
            "schemas/cdd/contract.cue",
            "schemas/cdd/boundary_decision.cue",
            "schemas/cdd/receipt.cue",
        ],
    },
    "cnos.cdd.cds.receipt.v1": {
        "definition": "#CDSReceipt",
        "schema_files": [
            "schemas/cds/receipt.cue",
        ],
    },
    "cnos.cdd.cdr.receipt.v1": {
        "definition": "#CDRReceipt",
        "schema_files": [
            "schemas/cdr/receipt.cue",
        ],
    },
}

# Required evidence_refs keys per protocol (for the friendlier counterfeit
# diagnostic — CUE already enforces these structurally).
CDS_REQUIRED_EVIDENCE_REFS = [
    "evidence_root",
    "self_coherence",
    "beta_review",
    "alpha_closeout",
    "beta_closeout",
    "gamma_closeout",
    "diff",
]
CDR_REQUIRED_EVIDENCE_REFS = ["claim", "data", "method", "result"]


def now_iso():
    return datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def repo_root_default():
    try:
        out = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True,
        )
        return Path(out.stdout.strip())
    except (subprocess.CalledProcessError, FileNotFoundError):
        return Path.cwd()


def load_yaml(path):
    """Load YAML; prefer PyYAML, fall back to cue export."""
    try:
        import yaml
        with open(path, "r", encoding="utf-8") as f:
            return yaml.safe_load(f)
    except ImportError:
        # Fallback: use cue export to coerce YAML to JSON, then json.loads.
        out = subprocess.run(
            ["cue", "export", "--out", "json", str(path)],
            capture_output=True, text=True, check=False,
        )
        if out.returncode != 0:
            raise RuntimeError(f"cannot parse YAML {path}: {out.stderr}")
        return json.loads(out.stdout)


def emit_verdict(result, failed_predicates, warnings, receipt_path,
                 contract_path, evidence_root):
    """Build a ValidationVerdict dict matching the JSON Schema."""
    input_refs = {"receipt_ref": str(receipt_path)}
    if contract_path:
        input_refs["contract_ref"] = str(contract_path)
    if evidence_root:
        input_refs["evidence_root_ref"] = str(evidence_root)
    return {
        "result": result,
        "failed_predicates": failed_predicates,
        "warnings": warnings,
        "provenance": {
            "validator_identity": V_IDENTITY,
            "validator_version": V_VERSION,
            "checked_at": now_iso(),
            "input_refs": input_refs,
        },
    }


# ---------------------------------------------------------------------------
# AC2 + AC3 + AC4 + AC5 — CUE structural validation
# ---------------------------------------------------------------------------

def cue_vet(receipt_path, dispatch_entry, repo_root):
    """Invoke `cue vet -c -d <def> <schema_files...> <receipt>`.

    Returns (ok: bool, diagnostics: list[str]).
    """
    schema_paths = [str(repo_root / sf) for sf in dispatch_entry["schema_files"]]
    cmd = ["cue", "vet", "-c", "-d", dispatch_entry["definition"]]
    cmd.extend(schema_paths)
    cmd.append(str(receipt_path))
    out = subprocess.run(cmd, capture_output=True, text=True, check=False,
                         cwd=str(repo_root))
    if out.returncode == 0:
        return True, []
    diagnostics = []
    for line in (out.stderr + out.stdout).splitlines():
        line = line.rstrip()
        if line:
            diagnostics.append(line)
    return False, diagnostics


# ---------------------------------------------------------------------------
# AC6 + AC8 — Counterfeit-receipt rule predicates
# ---------------------------------------------------------------------------

PLACEHOLDER_PATTERNS = [
    "git_diff(",
    "sha256:",
    "@sha256:",
    "issue:",
    "@merge_sha_placeholder",
    "@contract_sha_placeholder",
    "@draft",
    "@commit_sha_placeholder",
]


def is_filesystem_path(s):
    """Heuristic: is the string a real-looking filesystem path V should try to
    dereference, vs. a placeholder/synthetic ref?"""
    if not isinstance(s, str) or not s:
        return False
    for ph in PLACEHOLDER_PATTERNS:
        if ph in s:
            return False
    # Strip a trailing `@<ref>` placeholder if present.
    bare = s.split("@", 1)[0]
    if not bare:
        return False
    # Real paths start with . or / or are bare relative paths to existing files.
    if bare.startswith(".") or bare.startswith("/"):
        return True
    # Bare relative paths containing a slash and a file-shaped extension count.
    if "/" in bare and ("." in bare.rsplit("/", 1)[-1]):
        return True
    return False


def rule_c4_evidence_deref(receipt, repo_root, failed_predicates):
    """C4 — for each evidence_refs entry that looks like a real path, assert
    the file exists at repo_root / path."""
    evidence_refs = receipt.get("evidence_refs") or {}
    if not isinstance(evidence_refs, dict):
        return
    for key, value in evidence_refs.items():
        # Each value is either a single ref or a list of refs.
        candidates = value if isinstance(value, list) else [value]
        for ref in candidates:
            if not is_filesystem_path(ref):
                continue
            bare = ref.split("@", 1)[0]
            full = (repo_root / bare) if not bare.startswith("/") else Path(bare)
            if not full.exists():
                failed_predicates.append({
                    "predicate": "counterfeit.evidence_ref_unresolved",
                    "evidence_ref": f"{key}: {ref}",
                    "diagnostic": f"evidence_ref '{key}' points at non-existent path: {bare}",
                })


def _extract_actor(file_path):
    """Try to read an explicit 'Actor:' or 'Author:' or YAML frontmatter field
    from a closure-record markdown file. Returns the actor string or None."""
    try:
        text = Path(file_path).read_text(encoding="utf-8")
    except (OSError, UnicodeDecodeError):
        return None
    # Look for any of: "Actor:", "α actor:", "β actor:", "Author:", "alpha-actor:",
    # "beta-actor:", in the first ~40 lines (frontmatter / metadata block).
    for i, line in enumerate(text.splitlines()[:60]):
        lower = line.lower().strip()
        for prefix in ("actor:", "α actor:", "β actor:", "alpha actor:",
                       "beta actor:", "author:", "alpha-actor:", "beta-actor:"):
            if lower.startswith(prefix):
                return line.split(":", 1)[1].strip()
    return None


def _git_log_author(repo_root, file_path):
    """Read the most recent git author email for a file. Returns None if not
    tracked or git not available."""
    try:
        out = subprocess.run(
            ["git", "log", "-1", "--format=%ae", "--", str(file_path)],
            capture_output=True, text=True, check=False, cwd=str(repo_root),
        )
        if out.returncode == 0 and out.stdout.strip():
            return out.stdout.strip()
    except (subprocess.CalledProcessError, FileNotFoundError):
        pass
    return None


def is_collapsed_mode(receipt):
    """Receipts authored under γ+α+β-collapsed-on-δ mode declare
    `mode: collapsed` at the top level. V's structural review-independence
    rules (C1 actor_separation, C2 verdict_precedes_merge) emit warnings
    rather than failed_predicates in this mode — the receipt explicitly
    acknowledges the collapse, and the resulting degraded trust signal is
    honest.

    Collapsed mode is the wave-manifest pattern used across cycles
    375/377/378/388/389. The acknowledgment lives in the receipt (not
    inferred by V); V is honest about the resulting structural-independence
    degradation by surfacing it as a warning.
    """
    return receipt.get("mode") == "collapsed"


def rule_c1_actor_separation(receipt, repo_root, failed_predicates, warnings):
    """C1 — α actor ≠ β actor. Only fires for CDS receipts.

    When the receipt declares `mode: collapsed`, the rule emits a warning
    rather than a failed_predicate. The collapse mode acknowledges that
    structural review-independence is degraded by design (single-actor
    γ+α+β-on-δ cycle).
    """
    if receipt.get("protocol_id") != "cnos.cdd.cds.receipt.v1":
        return
    evidence_refs = receipt.get("evidence_refs") or {}
    alpha_path = evidence_refs.get("alpha_closeout")
    beta_path = evidence_refs.get("beta_closeout")
    if not alpha_path or not beta_path:
        return  # CUE already failed; let that diagnostic carry.
    # Strip @-ref placeholders.
    a_bare = alpha_path.split("@", 1)[0] if isinstance(alpha_path, str) else None
    b_bare = beta_path.split("@", 1)[0] if isinstance(beta_path, str) else None
    if not a_bare or not b_bare:
        return
    a_full = repo_root / a_bare
    b_full = repo_root / b_bare
    if not a_full.exists() or not b_full.exists():
        return  # C4 already flagged it.

    # Prefer explicit frontmatter actor; fall back to git log author.
    a_actor = _extract_actor(a_full) or _git_log_author(repo_root, a_bare)
    b_actor = _extract_actor(b_full) or _git_log_author(repo_root, b_bare)
    if a_actor is None or b_actor is None:
        warnings.append(
            f"counterfeit.actor_separation: could not determine actors for "
            f"{a_bare} or {b_bare}; rule skipped."
        )
        return
    if a_actor.strip().lower() == b_actor.strip().lower():
        msg = (
            f"α and β closeout authored by same actor: '{a_actor}'. "
            f"Structural review-independence requires distinct actors "
            f"(per RECEIPT-VALIDATION.md §Q4 and CCNF kernel doctrine)."
        )
        if is_collapsed_mode(receipt):
            warnings.append(
                f"counterfeit.actor_separation (collapsed-mode acknowledged): {msg}"
            )
        else:
            failed_predicates.append({
                "predicate": "counterfeit.actor_separation",
                "evidence_ref": f"alpha_closeout / beta_closeout",
                "diagnostic": msg,
            })


def _git_commit_time(repo_root, file_path):
    """Return ISO 8601 committer time for the most recent commit touching the
    file, or None."""
    try:
        out = subprocess.run(
            ["git", "log", "-1", "--format=%cI", "--", str(file_path)],
            capture_output=True, text=True, check=False, cwd=str(repo_root),
        )
        if out.returncode == 0 and out.stdout.strip():
            return out.stdout.strip()
    except (subprocess.CalledProcessError, FileNotFoundError):
        pass
    return None


def _parse_iso(ts):
    """Parse ISO 8601 timestamp to datetime. Returns None on failure."""
    if not ts or not isinstance(ts, str):
        return None
    # Normalize Z → +00:00 for fromisoformat compatibility on py<3.11.
    s = ts.rstrip()
    if s.endswith("Z"):
        s = s[:-1] + "+00:00"
    try:
        return datetime.datetime.fromisoformat(s)
    except ValueError:
        return None


def rule_c2_verdict_precedes_merge(receipt, repo_root, failed_predicates, warnings):
    """C2 — β closeout commit time T_β ≤ boundary_decision.decided_at T_δ.

    For CDS only. When git times unavailable: degrade to a structural check
    (β closeout exists and non-empty before action ∈ {accept, release}).
    """
    if receipt.get("protocol_id") != "cnos.cdd.cds.receipt.v1":
        return
    boundary = receipt.get("boundary_decision") or {}
    decided_at = boundary.get("decided_at")
    action = boundary.get("action")
    if action not in ("accept", "release"):
        return  # The constraint only matters for terminal-accept actions.
    evidence_refs = receipt.get("evidence_refs") or {}
    beta_path = evidence_refs.get("beta_closeout")
    if not beta_path or not isinstance(beta_path, str):
        return
    b_bare = beta_path.split("@", 1)[0]
    b_full = repo_root / b_bare
    if not b_full.exists():
        return  # C4 carries it.

    t_beta = _git_commit_time(repo_root, b_bare)
    t_delta = _parse_iso(decided_at)
    # Fallback: file mtime when git has no record (uncommitted-yet fixture).
    if not t_beta:
        try:
            mtime = b_full.stat().st_mtime
            t_beta = datetime.datetime.fromtimestamp(
                mtime, tz=datetime.timezone.utc
            ).strftime("%Y-%m-%dT%H:%M:%S+00:00")
        except OSError:
            t_beta = None
    if t_beta and t_delta:
        t_beta_dt = _parse_iso(t_beta)
        if t_beta_dt and t_beta_dt > t_delta:
            msg = (
                f"β closeout commit T_β={t_beta} postdates δ decision T_δ={decided_at}. "
                f"β verdict must precede merge per RECEIPT-VALIDATION.md §Q1."
            )
            if is_collapsed_mode(receipt):
                warnings.append(
                    f"counterfeit.verdict_precedes_merge (collapsed-mode acknowledged): {msg}"
                )
            else:
                failed_predicates.append({
                    "predicate": "counterfeit.verdict_precedes_merge",
                    "evidence_ref": f"beta_closeout commit time: {t_beta}; boundary_decision.decided_at: {decided_at}",
                    "diagnostic": msg,
                })
            return
    # Fallback structural check: closeout exists, non-empty.
    if b_full.stat().st_size == 0:
        failed_predicates.append({
            "predicate": "counterfeit.verdict_precedes_merge",
            "evidence_ref": f"beta_closeout: {b_bare}",
            "diagnostic": (
                f"β closeout file is empty; no β verdict to precede δ accept/release."
            ),
        })


def rule_c3_override_does_not_rewrite(receipt, failed_predicates):
    """C3 — override.original_validation_verdict.verdict == validation.verdict.

    All protocols.
    """
    boundary = receipt.get("boundary_decision") or {}
    if boundary.get("action") != "override":
        return
    override = boundary.get("override") or {}
    original = override.get("original_validation_verdict") or {}
    declared_in_override = original.get("verdict")
    declared_in_validation = (receipt.get("validation") or {}).get("verdict")
    if declared_in_override is None or declared_in_validation is None:
        return  # CUE has structural responsibility here.
    if declared_in_override != declared_in_validation:
        failed_predicates.append({
            "predicate": "counterfeit.override_does_not_rewrite",
            "evidence_ref": "boundary_decision.override.original_validation_verdict.verdict",
            "diagnostic": (
                f"override claims original verdict '{declared_in_override}' but "
                f"receipt.validation.verdict is '{declared_in_validation}'. "
                f"Override never rewrites the ValidationVerdict (RECEIPT-VALIDATION.md §Q4)."
            ),
        })


def rule_c5_protocol_id_mismatch(receipt, failed_predicates):
    """C5 — protocol_id declares cds.receipt.v1 but missing required keys
    (or cdr.receipt.v1 but missing required keys). Friendlier diagnostic than
    raw `cue vet`."""
    protocol_id = receipt.get("protocol_id")
    evidence_refs = receipt.get("evidence_refs") or {}
    if not isinstance(evidence_refs, dict):
        return
    if protocol_id == "cnos.cdd.cds.receipt.v1":
        missing = [k for k in CDS_REQUIRED_EVIDENCE_REFS if k not in evidence_refs]
        if missing:
            failed_predicates.append({
                "predicate": "counterfeit.protocol_id_mismatch",
                "evidence_ref": "evidence_refs",
                "diagnostic": (
                    f"protocol_id declares cnos.cdd.cds.receipt.v1 but "
                    f"missing required CDS evidence_refs keys: {missing}"
                ),
            })
    elif protocol_id == "cnos.cdd.cdr.receipt.v1":
        missing = [k for k in CDR_REQUIRED_EVIDENCE_REFS if k not in evidence_refs]
        if missing:
            failed_predicates.append({
                "predicate": "counterfeit.protocol_id_mismatch",
                "evidence_ref": "evidence_refs",
                "diagnostic": (
                    f"protocol_id declares cnos.cdd.cdr.receipt.v1 but "
                    f"missing required CDR evidence_refs keys: {missing}"
                ),
            })


# ---------------------------------------------------------------------------
# Main entry
# ---------------------------------------------------------------------------

def validate(receipt_path, contract_path, repo_root, structural_only=False):
    """Run V over (contract, receipt) → ValidationVerdict.

    Per CCNF: V's signature is Contract × Receipt → ValidationVerdict. The
    contract path is optional in practice — V's predicates today are derived
    from the receipt + schemas; the contract reference is recorded in
    provenance.input_refs.contract_ref but a missing contract surfaces only
    as a warning.

    `structural_only=True` runs only CUE structural validation and the
    counterfeit rules that don't require filesystem dereference (C3, C5).
    Useful for shape-demonstrating fixtures (CDR's cph-anchored fixture, the
    invalid-* fixtures whose evidence_refs are not load-bearing). The full
    mode (default) additionally runs C1 actor_separation, C2
    verdict_precedes_merge, and C4 evidence_ref_unresolved.
    """
    failed_predicates = []
    warnings = []

    # Parse receipt YAML.
    try:
        receipt = load_yaml(receipt_path)
    except Exception as e:  # noqa: BLE001
        return emit_verdict(
            "FAIL",
            [{
                "predicate": "v.receipt_parse",
                "evidence_ref": str(receipt_path),
                "diagnostic": f"could not parse receipt YAML: {e}",
            }],
            warnings,
            receipt_path, contract_path, None,
        )

    if not isinstance(receipt, dict):
        return emit_verdict(
            "FAIL",
            [{
                "predicate": "v.receipt_shape",
                "evidence_ref": str(receipt_path),
                "diagnostic": "receipt is not a YAML mapping at top level",
            }],
            warnings,
            receipt_path, contract_path, None,
        )

    # Determine evidence_root for the verdict provenance.
    evidence_refs = receipt.get("evidence_refs") or {}
    evidence_root = None
    if isinstance(evidence_refs, dict):
        er = evidence_refs.get("evidence_root")
        if isinstance(er, str):
            evidence_root = er.split("@", 1)[0]

    # Dispatch on protocol_id.
    protocol_id = receipt.get("protocol_id")
    if not protocol_id:
        failed_predicates.append({
            "predicate": "v.dispatch.missing_protocol_id",
            "evidence_ref": "receipt.protocol_id",
            "diagnostic": "receipt has no protocol_id; V cannot dispatch (per #388 README §protocol_id dispatch convention).",
        })
    elif protocol_id not in DISPATCH:
        failed_predicates.append({
            "predicate": "v.dispatch.unknown_protocol_id",
            "evidence_ref": f"receipt.protocol_id: {protocol_id}",
            "diagnostic": f"unknown protocol_id: {protocol_id}. Known: {sorted(DISPATCH)}",
        })
    else:
        # AC2 / AC3 / AC4 / AC5 — CUE structural validation.
        dispatch_entry = DISPATCH[protocol_id]
        ok, diagnostics = cue_vet(receipt_path, dispatch_entry, repo_root)
        if not ok:
            for d in diagnostics:
                failed_predicates.append({
                    "predicate": "cue.structural_vet",
                    "evidence_ref": f"protocol_id: {protocol_id} ({dispatch_entry['definition']})",
                    "diagnostic": d,
                })

    # AC6 / AC8 — counterfeit-receipt rules.
    # C5 first (friendly diagnostic; runs even when CUE fails). Filesystem-free.
    rule_c5_protocol_id_mismatch(receipt, failed_predicates)
    # C3 — override does not rewrite verdict. Filesystem-free.
    rule_c3_override_does_not_rewrite(receipt, failed_predicates)
    if not structural_only:
        # C4 — evidence deref.
        rule_c4_evidence_deref(receipt, repo_root, failed_predicates)
        # C1 — actor separation (CDS only).
        rule_c1_actor_separation(receipt, repo_root, failed_predicates, warnings)
        # C2 — β verdict precedes merge (CDS only).
        rule_c2_verdict_precedes_merge(receipt, repo_root, failed_predicates, warnings)
    else:
        warnings.append(
            "V running in --structural-only mode: skipping evidence-ref "
            "dereference (C4), actor-separation (C1), and "
            "verdict-precedes-merge (C2) rules."
        )

    # Contract presence (warn-only; the contract_ref is recorded in provenance
    # but its existence on disk is not load-bearing for AC1-AC8).
    if contract_path:
        cp = Path(contract_path)
        if not cp.is_absolute():
            cp = repo_root / contract_path
        if not cp.exists():
            warnings.append(
                f"contract_ref points at non-existent path: {contract_path}; "
                f"V proceeds (contract presence is not load-bearing)."
            )

    result = "PASS" if not failed_predicates else "FAIL"
    return emit_verdict(result, failed_predicates, warnings,
                        receipt_path, contract_path, evidence_root)


def render_prose(verdict, receipt_path):
    """Human-readable summary of the verdict (default stdout when --json not set)."""
    lines = []
    icon = "PASS" if verdict["result"] == "PASS" else "FAIL"
    lines.append(f"V verdict on {receipt_path}: {icon}")
    lines.append(f"  validator: {verdict['provenance']['validator_identity']} "
                 f"@ {verdict['provenance']['validator_version']}")
    lines.append(f"  checked_at: {verdict['provenance']['checked_at']}")
    if verdict["failed_predicates"]:
        lines.append(f"  failed_predicates ({len(verdict['failed_predicates'])}):")
        for fp in verdict["failed_predicates"]:
            lines.append(f"    - [{fp['predicate']}] {fp['diagnostic']}")
            if "evidence_ref" in fp:
                lines.append(f"        evidence_ref: {fp['evidence_ref']}")
    if verdict["warnings"]:
        lines.append(f"  warnings ({len(verdict['warnings'])}):")
        for w in verdict["warnings"]:
            lines.append(f"    - {w}")
    return "\n".join(lines)


def main():
    parser = argparse.ArgumentParser(
        description="V — Contract × Receipt → ValidationVerdict.",
    )
    parser.add_argument("receipt", help="path to the receipt YAML")
    parser.add_argument("--contract", default=None,
                        help="path to the contract (issue body / equivalent); optional")
    parser.add_argument("--json", action="store_true",
                        help="emit JSON verdict to stdout (default: prose)")
    parser.add_argument("--repo-root", default=None,
                        help="repo root override (default: git rev-parse --show-toplevel)")
    parser.add_argument("--structural-only", action="store_true",
                        help="skip filesystem-dereference rules (C1/C2/C4); "
                             "useful for shape-demonstrating fixtures whose "
                             "evidence_refs are placeholders.")
    args = parser.parse_args()

    repo_root = Path(args.repo_root) if args.repo_root else repo_root_default()
    receipt_path = Path(args.receipt)
    if not receipt_path.is_absolute():
        # Resolve relative-to-cwd, but record the path the operator passed in.
        receipt_path = Path(os.path.abspath(receipt_path))

    if not receipt_path.exists():
        print(f"V: receipt not found: {receipt_path}", file=sys.stderr)
        sys.exit(2)

    # Verify `cue` is available before dispatch.
    try:
        out = subprocess.run(["cue", "version"], capture_output=True, text=True,
                             check=False)
        if out.returncode != 0:
            print("V: `cue` is required but not runnable on PATH.", file=sys.stderr)
            sys.exit(2)
    except FileNotFoundError:
        print("V: `cue` is required but not found on PATH.", file=sys.stderr)
        sys.exit(2)

    try:
        verdict = validate(receipt_path, args.contract, repo_root,
                           structural_only=args.structural_only)
    except Exception as e:  # noqa: BLE001
        print(f"V: internal error: {e}", file=sys.stderr)
        sys.exit(2)

    if args.json:
        print(json.dumps(verdict, indent=2))
    else:
        print(render_prose(verdict, args.receipt))

    sys.exit(0 if verdict["result"] == "PASS" else 1)


if __name__ == "__main__":
    main()
