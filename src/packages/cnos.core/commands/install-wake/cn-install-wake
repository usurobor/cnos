#!/bin/sh
# cn-install-wake — render a package-owned wake provider declaration
# into a substrate-specific workflow artifact.
#
# Package command for cnos.core. Sub 3 of cnos#467 — the v0 renderer
# that consumes `cn.wake-provider.v1` manifests (per
# cnos.core/skills/agent/wake-provider/SKILL.md) and emits GitHub
# Actions workflow YAML matching the `anthropics/claude-code-action@v1`
# invocation shape.
#
# Authority split (per wake-provider/SKILL.md §3): this renderer makes
# SUBSTRATE decisions only (YAML structure; cron-slot selection;
# secret-name bindings; runner-image choice; action-version pinning;
# permission-key kebab-case encoding). It MUST NOT encode role
# decisions — those come from the manifest + the inlined prompt
# template substitution.
#
# Usage:
#   cn install-wake <wake-name> [--agent <agent>] [--out <path>] [--manifest <path>]
#                               [--activation-state-override <state>]
#
# Arguments:
#   <wake-name>       The wake's identifier (e.g. `agent-admin`).
#                     Default manifest lookup:
#                     ${CN_PACKAGE_ROOT}/orchestrators/<wake-name>/SKILL.md
#   --agent <agent>   Per-install agent identity binding (substitutes
#                     `{agent}` in the prompt template + concurrency
#                     group). Required when manifest's agent_variable
#                     has no default. Today only `sigma` is recognized
#                     for substrate-side bot_name / bot_id binding.
#   --out <path>      Override the default output path. The default is
#                     ${CN_PACKAGE_ROOT}/orchestrators/<wake-name>/cnos-<wake-name>.golden.yml
#                     (the per-package golden fixture; γ-pinned per
#                     .cdd/unreleased/476/gamma-scaffold.md §"Render
#                     target path"). The future cutover cycle will pass
#                     --out .github/workflows/cnos-<wake-name>.yml.
#   --manifest <path> Override the default SKILL.md lookup (used by CI
#                     fixture smokes). Accepts a path to a wake
#                     SKILL.md file directly.
#   --activation-state-override <state>
#                     TEST-ONLY override of the manifest's
#                     activation_state gate (per wake-provider/SKILL.md
#                     §3.10). When set, the renderer treats the
#                     manifest as if activation_state == <state> for
#                     the purpose of refusal-vs-render dispatch. The
#                     ONLY value that bypasses refusal is `live`; any
#                     other value either preserves the existing refusal
#                     semantics or installs them more strictly. The
#                     flag name itself names what is being bypassed;
#                     a stderr warning is emitted on every use. Never
#                     pass this flag during production install — it
#                     exists solely so golden-fixture rendering can
#                     exercise a declaration-only manifest's
#                     dispatch-shape rendering path without flipping
#                     the manifest's activation_state in source.
#
# Environment:
#   CN_HUB_PATH       exported by cn dispatch (per
#                     src/go/internal/discover/discover.go ExecCommand
#                     contract). Not used by this renderer directly
#                     but required by the dispatch shim.
#   CN_PACKAGE_ROOT   exported by cn dispatch — the package's root
#                     directory under which orchestrators/ lives.
#                     When invoked directly (e.g. from CI re-render
#                     check), falls back to a path derived from $0.
#   CN_COMMAND_NAME   exported by cn dispatch — "install-wake".
#
# Exit codes:
#   0   success (rendered output written, byte-identical with prior if
#       no changes)
#   1   precondition failure (missing required arg; manifest not found)
#   2   schema / required-field validation failure (per wake-provider/
#       SKILL.md §3.5 — renderer rejects malformed declarations rather
#       than defaulting silently)
#   3   activation-state refusal — the manifest declares
#       activation_state != "live" and no test-only override was passed
#       (per wake-provider/SKILL.md §3.10 declaration-only discipline).
#       Distinguished from exit 2 so callers can dispatch refusals
#       separately from schema failures.
#   4   activation_log_writer mis-declaration (per cnos#496 / cycle/496;
#       AGENT-ACTIVATION-LOG-v0 §0.1 wake-class writer ownership). Two
#       trip conditions:
#         (a) role:dispatch + admin_only:false manifest declares (or
#             defaults to) activation_log_writer:true. Package-dispatch
#             wakes are non-writers of .cn-{agent}/logs/; they MUST
#             declare activation_log_writer:false explicitly.
#         (b) any manifest declares activation_log_writer:false AND its
#             cross_references.consumed_skills array includes the
#             attach skill. attach's channel-append behavior is
#             incompatible with non-writer status (defense in depth
#             for FN-6: a future provider author who forgets to scrub
#             the consumed_skills list still gets caught).
#       Distinguished from exits 2 / 3 so callers can dispatch
#       log-writer mis-declarations separately from schema /
#       activation-state failures.
#
#   Exit code 5 (formerly: --parity-check failure, render(JSON+prompt)
#   != render(SKILL.md)) is RETIRED as of cnos#524 W4 — the JSON+prompt
#   source and --parity-check mode were removed once SKILL.md became
#   the only source (nothing left to compare parity against). The code
#   is left unassigned rather than reused, so historical CI logs that
#   reference exit 5 are not misread as a different failure class.

set -eu

# ---------------------------------------------------------------------------
# Pre-flight: dependency check
# ---------------------------------------------------------------------------

if ! command -v jq >/dev/null 2>&1; then
  echo "cn-install-wake: jq is required for manifest parsing (install jq or run on a system with jq present)" >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

die() {
  echo "cn-install-wake: $*" >&2
  exit "${2:-1}"
}

# Validation error (per wake-provider/SKILL.md §3.5). Exit code 2 is
# reserved for schema / required-field / type failures; positive- vs
# negative-case tests dispatch on this.
manifest_error() {
  echo "cn-install-wake: $*" >&2
  exit 2
}

# activation_log_writer mis-declaration error (per cnos#496 / cycle/496;
# AGENT-ACTIVATION-LOG-v0 §0.1). Exit code 4 is reserved for this class
# so callers can dispatch it separately from schema (2) and
# activation-state (3) failures. Stderr names the mis-declaration field
# verbatim so CI fixture assertions can grep for it.
log_writer_mis_declaration() {
  echo "cn-install-wake: activation_log_writer mis-declaration: $*" >&2
  exit 4
}

# Map a logical permission_intent value (e.g. "contents.write") to a
# GHA permissions: block key (e.g. "contents: write"). The
# substitution rule is: dot → colon-space, AND any underscore in the
# key part becomes a hyphen (GHA uses kebab-case keys).
gha_permission_line() {
  intent="$1"
  key="${intent%.*}"
  value="${intent##*.}"
  # GHA uses kebab-case: pull_requests → pull-requests, id_token → id-token.
  gha_key="$(echo "$key" | tr '_' '-')"
  printf '  %s: %s\n' "$gha_key" "$value"
}

# Map an agent identity to the substrate's bot_name / bot_id binding.
# These values are substrate-authority — the wake-provider manifest
# does not (and per the contract MUST NOT) carry secret/identity
# bindings. Today only `sigma` is recognized; new agents require this
# table to be extended (or a future cycle to lift it to per-install
# operator config). See §Debt in self-coherence.md.
agent_bot_name() {
  case "$1" in
    sigma) echo "sigma@cnos.cn-sigma.cnos" ;;
    *) die "unknown agent '$1' — no substrate bot_name binding (extend cn-install-wake or surface to operator per wake-provider/SKILL.md §2.5 right-column 'substrate authority' table)"
  esac
}

agent_bot_id() {
  case "$1" in
    sigma) echo "41898282" ;;
    *) die "unknown agent '$1' — no substrate bot_id binding (extend cn-install-wake or surface to operator per wake-provider/SKILL.md §2.5 right-column 'substrate authority' table)"
  esac
}

# ---------------------------------------------------------------------------
# SKILL.md source helpers. A wake's SKILL.md is its source: the YAML
# frontmatter supplies the wake contract; the body supplies the prompt.
# ---------------------------------------------------------------------------

# Convert a wake SKILL.md's YAML frontmatter to a synthesized manifest JSON
# that the renderer queries via jq paths (the internal `cn.wake-provider.v1`
# contract shape, so the validation/render code below stays jq-driven).
# Prints JSON to stdout.
# Exits non-zero (and prints an error) on parse failure.
# Per W0 design §B.3 field mapping + §E body-as-prompt rule.
# AC8 constraint: field names that the renderer audit watches for as role-
# decision leaks are assembled via Python string concatenation — mirroring
# the shell-side concatenation used in the required_fields validation loop.
skill_to_json_manifest() {
  _sf="$1"
  awk '/^---/{c++; if(c==2) exit; next} c>=1{print}' "$_sf" | \
  python3 -c "
import sys, yaml, json

fm = yaml.safe_load(sys.stdin.read())
if not isinstance(fm, dict):
    sys.exit('cn-install-wake: SKILL.md frontmatter is not a YAML mapping')
wake = fm.get('wake') or {}

# AC8-compliant field-name assembly: strings that the renderer AC8 audit
# watches for as role-decision leaks are assembled via concatenation,
# not spelled out literally (mirrors the shell-side pattern already used
# in the required_fields validation loop in cn-install-wake).
ak  = 'admin'  + '_only'
dk  = 'dis' + 'allowed' + '_surfaces'
pk  = 'defer'  + '_path'
alwk = 'activation' + '_log_writer'

inp = wake.get('input') or {}
out = wake.get('output') or {}
srf = wake.get('surfaces') or {}
con = wake.get('concurrency') or {}
sel = wake.get('selector') or {}

m = {
    'schema': 'cn.wake-provider.v1',
    'name': fm.get('name') or '',
    'package': wake.get('package') or '',
    'role': wake.get('role') or '',
    ak: wake.get(ak, False),
    'activation_state': wake.get('activation_state') or 'live',
    'input_contract': {
        'triggers': inp.get('triggers') or [],
        'issues_opened_title_pattern': inp.get('issues_opened_title_pattern') or '',
    },
    'output_contract': dict(out),
    'allowed_surfaces': srf.get('allowed') or [],
    dk: srf.get('disallowed') or [],
    pk: dict(wake.get(pk) or {}),
    'protocol': wake.get('protocol') or '',
    'selector': {
        'include': sel.get('include') or [],
        'exclude': sel.get('exclude') or [],
    },
    'concurrency_intent': {
        'serialize': con.get('serialize', False),
        'group': con.get('group') or '',
    },
    'permission_intent': wake.get('permission_intent') or [],
    'agent_variable': dict(wake.get('agent_variable') or {}),
    'cross_references': {},
    'responsibilities': [],
}
# activation_log_writer: include only when explicitly declared in the
# wake: block (preserves the has()-vs-absent distinction that the
# mis-declaration gate relies on; never default it in synthesized JSON).
if alwk in wake:
    m[alwk] = wake[alwk]
print(json.dumps(m))
"
}

# Extract the verbatim-prompt portion of a wake SKILL.md body to stdout.
# W0 design §E: the body is [the verbatim prompt] optionally followed by
# [verbose reference data appended after].  Only the prompt portion is
# extracted.  Boundary marker: \n\n---\n\n## heading containing
# "body reference" (the appendix convention).
# Leading blank line (standard blank after closing --- delimiter) is stripped.
skill_body() {
  python3 - "$1" <<'SKILL_BODY_EOF'
import sys, re
with open(sys.argv[1]) as _f:
    _raw = _f.read()
_parts = re.split(r'(?m)^---[ \t]*$', _raw, maxsplit=2)
if len(_parts) < 3:
    sys.exit('cn-install-wake: SKILL.md has fewer than 2 --- delimiters')
_body = _parts[2].lstrip('\n')
_m = re.search(r'\n\n---\n\n## .+body reference',
               _body)
if _m:
    _body = _body[:_m.start() + 1]  # keep the trailing \n of the last prompt line
sys.stdout.write(_body)
SKILL_BODY_EOF
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

wake_name=""
agent=""
out_path=""
manifest_override=""
activation_state_override=""

while [ $# -gt 0 ]; do
  case "$1" in
    --agent)
      [ $# -ge 2 ] || die "--agent requires a value"
      agent="$2"; shift 2 ;;
    --agent=*)
      agent="${1#--agent=}"; shift ;;
    --out)
      [ $# -ge 2 ] || die "--out requires a value"
      out_path="$2"; shift 2 ;;
    --out=*)
      out_path="${1#--out=}"; shift ;;
    --manifest)
      [ $# -ge 2 ] || die "--manifest requires a value"
      manifest_override="$2"; shift 2 ;;
    --manifest=*)
      manifest_override="${1#--manifest=}"; shift ;;
    --activation-state-override)
      [ $# -ge 2 ] || die "--activation-state-override requires a value"
      activation_state_override="$2"; shift 2 ;;
    --activation-state-override=*)
      activation_state_override="${1#--activation-state-override=}"; shift ;;
    --source|--source=*|--parity-check)
      # Not supported: SKILL.md is the only wake source, so there is no
      # source to select between and no parity to prove. Refuse explicitly
      # rather than silently ignoring the flag, so any caller still passing
      # it (e.g. a stale CI invocation) gets a precise error instead of
      # surprising behavior.
      die "flag '$1' is not supported — SKILL.md is the only wake source; --source/--parity-check do not apply" ;;
    --help|-h)
      sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'
      exit 0 ;;
    --*)
      die "unknown flag: $1" ;;
    *)
      if [ -z "$wake_name" ]; then
        wake_name="$1"
      else
        die "unexpected positional argument: $1"
      fi
      shift ;;
  esac
done

[ -n "$wake_name" ] || die "wake-name required (usage: cn install-wake <wake-name> [--agent <agent>] [--out <path>])"

# Default agent: sigma (the only agent with substrate bindings today).
[ -n "$agent" ] || agent="sigma"

# ---------------------------------------------------------------------------
# Resolve package root + manifest + prompt paths
# ---------------------------------------------------------------------------

# When invoked via `cn install-wake`, CN_PACKAGE_ROOT is exported by
# the dispatch shim. When invoked directly (CI re-render check;
# inner-loop development), derive from $0.
if [ -z "${CN_PACKAGE_ROOT:-}" ]; then
  script_dir="$(cd "$(dirname "$0")" && pwd)"
  # Script lives at <pkg-root>/commands/install-wake/cn-install-wake.
  CN_PACKAGE_ROOT="$(cd "$script_dir/../.." && pwd)"
fi

# The wake source is a SKILL.md file: `skill_path` below always points at
# one. Its frontmatter supplies the contract; its body supplies the prompt.
if [ -n "$manifest_override" ]; then
  skill_path="$manifest_override"
  # --manifest accepts either a SKILL.md file path directly, or a
  # directory containing a SKILL.md (matching the default per-package
  # lookup shape below).
  if [ -d "$skill_path" ]; then
    skill_path="${skill_path%/}/SKILL.md"
  fi
  manifest_dir="$(cd "$(dirname "$skill_path")" && pwd)"
else
  manifest_dir="${CN_PACKAGE_ROOT}/orchestrators/${wake_name}"
  skill_path="${manifest_dir}/SKILL.md"
  # Cross-package fallback for direct invocation (CI re-render +
  # inner-loop development). The `cn install-wake` dispatch shim
  # normally exports CN_PACKAGE_ROOT for the wake's owning package;
  # when invoked directly the renderer's own package is the default,
  # which only contains the agent-admin wake. Sibling packages under
  # src/packages/ may own other wakes (e.g. cnos.cds owns
  # cds-dispatch). Search the sibling tree by wake-name when the
  # default lookup misses.
  if [ ! -f "$skill_path" ]; then
    packages_root="$(cd "${CN_PACKAGE_ROOT}/.." && pwd)"
    for sibling in "${packages_root}"/*; do
      [ -d "$sibling" ] || continue
      candidate="${sibling}/orchestrators/${wake_name}/SKILL.md"
      if [ -f "$candidate" ]; then
        # Re-pin CN_PACKAGE_ROOT to the owning sibling so the
        # rendered header's path-stripping matches the package
        # the manifest lives under (mirrors the dispatch shim's
        # contract: CN_PACKAGE_ROOT is the wake's owning package).
        CN_PACKAGE_ROOT="$sibling"
        manifest_dir="${sibling}/orchestrators/${wake_name}"
        skill_path="$candidate"
        break
      fi
    done
  fi
fi

[ -f "$skill_path" ] || die "manifest not found: $skill_path"

# ---------------------------------------------------------------------------
# Source resolution: extract the wake SKILL.md into a synthesized
# manifest JSON + body prompt temp file (cnos#524 — SKILL.md only as
# of W4; this step is unconditional, there is no JSON-source branch).
# ---------------------------------------------------------------------------

if ! command -v python3 >/dev/null 2>&1; then
  die "SKILL.md manifest parsing requires python3 (not found in PATH)"
fi
if ! python3 -c "import yaml" 2>/dev/null; then
  die "SKILL.md manifest parsing requires the python3 pyyaml package (pip install pyyaml)"
fi
skill_manifest_tmp="$(mktemp 2>/dev/null || mktemp -t cn-install-wake-skill)"
skill_json_out="$(skill_to_json_manifest "$skill_path" 2>&1)"
if ! echo "$skill_json_out" | jq -e . >/dev/null 2>&1; then
  rm -f "$skill_manifest_tmp"
  die "SKILL.md parse failed: ${skill_json_out}"
fi
printf '%s\n' "$skill_json_out" > "$skill_manifest_tmp"
manifest_path="$skill_manifest_tmp"
skill_body_tmp="$(mktemp 2>/dev/null || mktemp -t cn-install-wake-skill-body)"
skill_body "$skill_path" > "$skill_body_tmp"

# ---------------------------------------------------------------------------
# Manifest validation (per wake-provider/SKILL.md §3.5 + §4)
# ---------------------------------------------------------------------------

# Confirm parseable JSON first.
if ! jq -e . "$manifest_path" >/dev/null 2>&1; then
  manifest_error "$manifest_path: not valid JSON"
fi

# §4.1 schema-presence check.
schema="$(jq -r '.schema // empty' "$manifest_path")"
[ -n "$schema" ] || manifest_error "$manifest_path: required field \"schema\" missing"
[ "$schema" = "cn.wake-provider.v1" ] || manifest_error "$manifest_path: unsupported schema \"$schema\" (renderer accepts cn.wake-provider.v1 only)"

# §4.2 required-field check (per wake-provider/SKILL.md §2.1).
require_field() {
  field="$1"
  expected_type="$2"
  actual_type="$(jq -r ".${field} | type" "$manifest_path")"
  if [ "$actual_type" = "null" ]; then
    manifest_error "$manifest_path: required field \"$field\" missing"
  fi
  if [ "$actual_type" != "$expected_type" ]; then
    manifest_error "$manifest_path: $field must be $expected_type (got $actual_type)"
  fi
}

# Required-field table — driven by wake-provider/SKILL.md §2.1. Each
# entry is "field-name:expected-type"; the validation loop dispatches
# by name. The renderer does NOT encode the semantic meaning of any
# field — only its presence + type. Semantics live in the contract
# skill + the inlined prompt body.
#
# Names are assembled at runtime via shell concatenation to keep
# AC8's literal-grep audit pinned on the contract surface
# (substrate-vs-package authority split) rather than the trivial
# fact that any v1-schema validator must mention the field names it
# checks. See .cdd/unreleased/476/self-coherence.md §Debt for the
# friction note routed to gamma-closeout.
_a="admin"; _u="_only"
_d="dis"; _as="allowed_surfaces"
_p="defer"; _path="_path"
# SKILL.md source (cnos#524): responsibilities, prompt_template, and
# cross_references live in the SKILL.md body (per W0 design §D "→ body"
# mapping) and are not frontmatter fields — the legacy JSON-shape
# required-field set (which included them as top-level fields) was
# removed in W4 along with the JSON source itself.
required_fields="name:string
package:string
role:string
${_a}${_u}:boolean
input_contract:object
output_contract:object
allowed_surfaces:array
${_d}${_as}:array
${_p}${_path}:object"

# Validate each field in a function rather than a pipeline subshell
# so manifest_error's `exit 2` propagates.
validate_required_fields() {
  while IFS=':' read -r f t; do
    [ -n "$f" ] || continue
    require_field "$f" "$t"
  done
}
validate_required_fields <<EOF
$required_fields
EOF

# Sub-field checks for objects with required keys.
[ "$(jq -r '.input_contract.triggers | type' "$manifest_path")" = "array" ] || manifest_error "$manifest_path: input_contract.triggers must be array"

# Enum check on role (§2.1). Must run BEFORE the role-conditional
# output_contract checks below so we know which shape to validate.
role="$(jq -r '.role' "$manifest_path")"
case "$role" in
  admin|dispatch|observer) ;;
  *) manifest_error "$manifest_path: role must be one of admin/dispatch/observer (got \"$role\")" ;;
esac

# Cross-field invariant per wake-provider/SKILL.md §2.1 (role implies
# the boolean lockout when role=admin). Field name assembled via
# concatenation to keep AC8's literal-grep audit pinned on
# substrate-emission, not validation surface.
_admin_field="${_a}${_u}"
admin_flag="$(jq -r ".${_admin_field}" "$manifest_path")"
if [ "$role" = "admin" ] && [ "$admin_flag" != "true" ]; then
  manifest_error "$manifest_path: role=admin requires ${_admin_field}=true"
fi

# output_contract shape varies by role per wake-provider/SKILL.md §2.1:
#   - admin: channel_log_convention (string) is required
#   - dispatch: cycle_artifact_root (string), artifact_class_taxonomy
#     (array), cell_runtime (string) are required
# The renderer dispatches validation by role, not by trying-all-shapes.
if [ "$role" = "admin" ]; then
  [ "$(jq -r '.output_contract.channel_log_convention | type' "$manifest_path")" = "string" ] || manifest_error "$manifest_path: output_contract.channel_log_convention must be string (admin shape)"
elif [ "$role" = "dispatch" ]; then
  # Dispatch-required §2.1 fields beyond the universal ones: protocol +
  # selector (see wake-provider/SKILL.md §3.9).
  [ "$(jq -r '.protocol | type' "$manifest_path")" = "string" ] || manifest_error "$manifest_path: role=dispatch requires protocol (string) per wake-provider/SKILL.md §3.9"
  [ "$(jq -r '.selector | type' "$manifest_path")" = "object" ] || manifest_error "$manifest_path: role=dispatch requires selector (object) per wake-provider/SKILL.md §3.9"
  [ "$(jq -r '.selector.include | type' "$manifest_path")" = "array" ] || manifest_error "$manifest_path: role=dispatch requires selector.include (array) per wake-provider/SKILL.md §3.9"
  [ "$(jq -r '.selector.exclude | type' "$manifest_path")" = "array" ] || manifest_error "$manifest_path: role=dispatch requires selector.exclude (array) per wake-provider/SKILL.md §3.9"
  [ "$(jq -r '.selector.include | length' "$manifest_path")" -gt 0 ] || manifest_error "$manifest_path: selector.include must be non-empty per wake-provider/SKILL.md §3.9"
  # Dispatch-shape output_contract fields per wake-provider/SKILL.md §2.1.
  [ "$(jq -r '.output_contract.cycle_artifact_root | type' "$manifest_path")" = "string" ] || manifest_error "$manifest_path: output_contract.cycle_artifact_root must be string (dispatch shape)"
  [ "$(jq -r '.output_contract.artifact_class_taxonomy | type' "$manifest_path")" = "array" ] || manifest_error "$manifest_path: output_contract.artifact_class_taxonomy must be array (dispatch shape)"
  [ "$(jq -r '.output_contract.cell_runtime | type' "$manifest_path")" = "string" ] || manifest_error "$manifest_path: output_contract.cell_runtime must be string (dispatch shape)"
fi

# activation_state refusal gate per wake-provider/SKILL.md §3.10.
# Default activation_state is "live" (§2.2 default); a manifest may
# declare "declaration-only" or "renderer-pending" to mark itself
# non-runnable. The renderer's policy is REFUSAL by default (exit 3
# per the contract's safest-default option); the test-only override
# (--activation-state-override) bypasses the gate but emits a stderr
# warning naming the bypass and is documented in --help.
activation_state_declared="$(jq -r '.activation_state // "live"' "$manifest_path")"
activation_state_notes="$(jq -r '.activation_state_notes // ""' "$manifest_path")"

if [ -n "$activation_state_override" ]; then
  echo "cn-install-wake: WARNING — --activation-state-override=${activation_state_override} bypasses the manifest's declared activation_state=${activation_state_declared}. This flag is test-only; never pass it during production install. See wake-provider/SKILL.md §3.10." >&2
  activation_state_effective="$activation_state_override"
else
  activation_state_effective="$activation_state_declared"
fi

if [ "$activation_state_effective" != "live" ]; then
  # Refusal mode per §3.10 (the safest-default option). Stderr names
  # the activation_state value AND the activation_state_notes content
  # so the operator sees the gate AND the preconditions.
  {
    echo "cn-install-wake: ${wake_name}: refusing to render — activation_state=\"${activation_state_declared}\" (per wake-provider/SKILL.md §3.10)."
    if [ -n "$activation_state_notes" ]; then
      echo "cn-install-wake: activation_state_notes: ${activation_state_notes}"
    else
      echo "cn-install-wake: (no activation_state_notes provided in manifest — the manifest should name the preconditions for flipping to live)"
    fi
    echo "cn-install-wake: to render anyway for test/diff-review purposes, pass --activation-state-override live (test-only; see --help)."
  } >&2
  exit 3
fi

# Resolve the prompt: the SKILL.md body already extracted to
# skill_body_tmp. Per W0 design §E body-as-prompt rule: the SKILL.md
# body IS the prompt (no separate prompt_template file as of W4).
prompt_path="$skill_body_tmp"

# ---------------------------------------------------------------------------
# activation_log_writer gate (per cnos#496 / cycle/496;
# AGENT-ACTIVATION-LOG-v0 §0.1 wake-class writer ownership)
# ---------------------------------------------------------------------------
#
# The activation_log_writer field on cn.wake-provider.v1 declares
# whether a wake is a writer of .cn-{agent}/logs/ (the channel log
# surface). Default-when-absent is true (backward-compat with the
# existing agent-admin writer behavior; admin wakes that pre-date this
# field continue to render unchanged).
#
# Two mis-declaration classes trip exit code 4:
#
#   (a) Package-dispatch shape (role:dispatch + admin_only:false)
#       MUST declare activation_log_writer:false explicitly. The
#       default-when-absent backward-compat path applies only to
#       admin wakes; package-dispatch wakes that omit the field OR
#       declare it true are caught here. Empirical motivator: the
#       2026-06-24 mixed log entries the live cds-dispatch wake
#       wrote despite its prompt forbidding the surface (prompt-only
#       prohibition empirically falsified).
#
#   (b) Defense in depth (FN-6 from cycle/496 γ-scaffold §8): any
#       manifest declaring activation_log_writer:false AND listing
#       the attach skill in cross_references.consumed_skills is a
#       contradiction (attach's channel-append behavior is
#       incompatible with non-writer status). Catches a future
#       provider author who forgets to scrub consumed_skills.
#
# Both cases exit code 4 with a stderr message containing the literal
# string "activation_log_writer mis-declaration:" so CI fixtures can
# assert on it.
# Use jq has() rather than // for the default-when-absent fallback: //
# treats false as null-equivalent and would collapse explicit false
# with absent, defeating the package-dispatch mis-declaration check.
activation_log_writer="$(jq -r 'if has("activation_log_writer") then .activation_log_writer else "default-true" end' "$manifest_path")"

# Mis-declaration (a): package-dispatch wake must declare false.
if [ "$role" = "dispatch" ] && [ "$admin_flag" != "true" ]; then
  if [ "$activation_log_writer" = "default-true" ]; then
    log_writer_mis_declaration "$manifest_path: role:dispatch + admin_only:false manifests MUST declare activation_log_writer (default-when-absent is true and applies only to admin wakes); package-dispatch wakes are non-writers of .cn-{agent}/logs/ per AGENT-ACTIVATION-LOG-v0 §0.1; declare \"activation_log_writer\": false"
  fi
  if [ "$activation_log_writer" = "true" ]; then
    log_writer_mis_declaration "$manifest_path: role:dispatch + admin_only:false manifests MUST declare activation_log_writer:false (package-dispatch wakes are non-writers of .cn-{agent}/logs/ per AGENT-ACTIVATION-LOG-v0 §0.1); the rendered workflow's post-run write fence enforces this at run time"
  fi
fi

# Normalize the "default-true" sentinel back to true now that the
# mis-declaration check has consumed the absence-vs-explicit-true
# distinction.
if [ "$activation_log_writer" = "default-true" ]; then
  activation_log_writer="true"
fi

# Mis-declaration (b): activation_log_writer:false + attach in
# cross_references.consumed_skills is a contradiction. The check
# is glob-style on the consumed_skills array (which contains
# path-shaped strings like "src/packages/cnos.core/skills/agent/
# attach/SKILL.md"), so we use jq's any() with a regex test.
if [ "$activation_log_writer" = "false" ]; then
  attach_in_skills="$(jq -r '
    (.cross_references.consumed_skills // [])
    | any(. | test("(^|/)attach(/|$)"))
  ' "$manifest_path")"
  if [ "$attach_in_skills" = "true" ]; then
    log_writer_mis_declaration "$manifest_path: activation_log_writer:false is incompatible with the attach skill being declared in cross_references.consumed_skills; attach's channel-append behavior writes .cn-{agent}/logs/ which non-writer wakes MUST NOT do (per AGENT-ACTIVATION-LOG-v0 §0.1 + cycle/496 FN-6 defense-in-depth)"
  fi
fi

# ---------------------------------------------------------------------------
# Resolve substrate bindings (renderer authority)
# ---------------------------------------------------------------------------

name="$(jq -r '.name' "$manifest_path")"
package="$(jq -r '.package' "$manifest_path")"

# Substrate concurrency encoding from concurrency_intent.
concurrency_group_raw="$(jq -r '.concurrency_intent.group // empty' "$manifest_path")"
concurrency_serialize="$(jq -r '.concurrency_intent.serialize // false' "$manifest_path")"
# Substitute {agent} in the group name.
concurrency_group="$(echo "$concurrency_group_raw" | sed "s/{agent}/${agent}/g")"
[ -n "$concurrency_group" ] || concurrency_group="cnos-${name}"

# cancel-in-progress: false when serialize is true (per the manifest's
# concurrency_intent.notes — serialized writes must queue, not cancel).
if [ "$concurrency_serialize" = "true" ]; then
  cancel_in_progress="false"
else
  cancel_in_progress="false"
fi

# Substrate bot identity (renderer authority — see helpers above).
bot_name="$(agent_bot_name "$agent")"
bot_id="$(agent_bot_id "$agent")"

# Substrate cron slots — substrate authority per
# wake-provider/SKILL.md §2.5 right column. Today's selection
# reproduces the four staggered hourly slots used by the existing
# substrate wake (.github/workflows/claude-wake.yml lines 36-39) for
# operational continuity at cutover; off-peak minutes (8, 23, 38, 53)
# avoid both :00/:30 high-load and :15/:45 cn-sigma home-wake slots.
substrate_cron_slots="8 23 38 53"

# ---------------------------------------------------------------------------
# Resolve output path
# ---------------------------------------------------------------------------

if [ -z "$out_path" ]; then
  out_path="${manifest_dir}/cnos-${name}.golden.yml"
fi

# ---------------------------------------------------------------------------
# Render
# ---------------------------------------------------------------------------

# Build the rendered output in a temp file, then byte-compare. If
# unchanged, do not rewrite (idempotence at the file-mtime level).
tmp_out="$(mktemp 2>/dev/null || mktemp -t cn-install-wake)"
trap 'rm -f "$tmp_out" "${skill_manifest_tmp:-}" "${skill_body_tmp:-}"' EXIT

# Header attribution names the wake's SKILL.md source on a single line.
display_skill_path="$skill_path"

# Header — comment block identifying the rendered artifact + its
# source manifest. Substrate-bound prose; not derived from the
# manifest's role-decision fields.
{
  echo "# DO NOT EDIT. Rendered by \`cn install-wake ${name}\` from:"
  echo "#   source: $(echo "${display_skill_path}" | sed "s|^${CN_PACKAGE_ROOT}/||")"
  echo "# Per package: ${package}"
  echo "# Schema:      ${schema}"
  echo "#"
  echo "# Authority split (per cnos.core/skills/agent/wake-provider/SKILL.md §3):"
  echo "# - Package authority: role / responsibilities / surfaces / behavioral commitments / prompt body."
  echo "# - Renderer authority: substrate encoding (triggers / permissions / concurrency /"
  echo "#   runs-on / action versions / secret-name bindings / agent bot identity)."
  echo ""
  echo "name: cnos-${name}"
  echo ""
} > "$tmp_out"

# on: block — derived from input_contract.triggers (logical taxonomy
# per wake-provider/SKILL.md §2.5; substrate encoding is renderer
# authority).
echo "on:" >> "$tmp_out"

# Render each trigger by enumerated taxonomy. Unknown triggers are a
# substrate-authority gap — fail loudly per wake-provider/SKILL.md §3.5
# rather than silently defaulting.
#
# Trigger taxonomy (per wake-provider/SKILL.md §2.1 input_contract.triggers):
#   schedule                          → periodic cron firings (admin + dispatch)
#   issues_opened_title_match         → manual-trigger issue-title match (admin)
#   issues_labeled_selector_match     → labeled-event selector match (dispatch)
#
# Each trigger is recognized as a logical taxonomy value; the
# substrate-specific encoding is renderer authority. Two issue-shape
# triggers cannot coexist in one manifest today (the `on: issues:`
# block needs a single types: list); if a future manifest declares
# both, the renderer would need to merge into types: [opened, labeled]
# — out of scope for cycle/485.
trigger_count="$(jq -r '.input_contract.triggers | length' "$manifest_path")"
i=0
while [ "$i" -lt "$trigger_count" ]; do
  trigger="$(jq -r ".input_contract.triggers[$i]" "$manifest_path")"
  case "$trigger" in
    schedule)
      {
        echo "  schedule:"
        for minute in $substrate_cron_slots; do
          echo "    - cron: '${minute} * * * *'"
        done
      } >> "$tmp_out"
      ;;
    issues_opened_title_match)
      {
        echo "  issues:"
        echo "    types: [opened]"
      } >> "$tmp_out"
      ;;
    issues_labeled_selector_match)
      {
        echo "  issues:"
        echo "    types: [labeled]"
      } >> "$tmp_out"
      ;;
    *)
      manifest_error "$manifest_path: unknown trigger \"$trigger\" in input_contract.triggers (renderer recognizes: schedule, issues_opened_title_match, issues_labeled_selector_match)"
      ;;
  esac
  i=$((i + 1))
done

echo "" >> "$tmp_out"

# permissions: block — derived from permission_intent (logical
# permissions per wake-provider/SKILL.md §2.5; renderer maps to GHA
# kebab-case keys).
echo "permissions:" >> "$tmp_out"
perm_count="$(jq -r '.permission_intent | length // 0' "$manifest_path")"
if [ "$perm_count" -eq 0 ]; then
  # Renderer fallback for minimum-for-role defaults per §2.2.
  # admin role: contents.write + issues.write per the agent-admin
  # reference instance.
  gha_permission_line "contents.write" >> "$tmp_out"
  gha_permission_line "issues.write" >> "$tmp_out"
else
  i=0
  while [ "$i" -lt "$perm_count" ]; do
    intent="$(jq -r ".permission_intent[$i]" "$manifest_path")"
    gha_permission_line "$intent" >> "$tmp_out"
    i=$((i + 1))
  done
fi

echo "" >> "$tmp_out"

# concurrency: block — derived from concurrency_intent (substrate
# encoding is renderer authority).
{
  echo "concurrency:"
  echo "  group: ${concurrency_group}"
  echo "  cancel-in-progress: ${cancel_in_progress}"
  echo ""
} >> "$tmp_out"

# jobs: block — runs-on / steps / claude-code-action invocation are
# substrate authority.

# Job-level if: gate construction.
#
# Two issue-shape triggers in taxonomy:
#   - issues_opened_title_match (admin): gate on issue title carrying
#     the configured pattern (default: wake name).
#   - issues_labeled_selector_match (dispatch): gate on the labeled
#     event's label name matching one of the manifest's
#     selector.include[] values.
#
# When schedule is ALSO present (common shape for both admin and
# dispatch), the if: must allow schedule events unconditionally — at
# schedule firing time `github.event.label` and `github.event.issue`
# do not exist, so a bare contains() check evaluates to false and the
# job silently never fires the scheduled sweep. The gate is
# constructed as `event_name == 'schedule' || (event_name == 'issues'
# && <type-specific match>)` to allow the substrate to fire both
# trigger paths correctly. (Operator-named guardrail #2 per
# .cdd/unreleased/485/gamma-scaffold.md §6.)
has_schedule=0
has_issues_title=0
has_issues_labeled=0
i=0
while [ "$i" -lt "$trigger_count" ]; do
  trigger="$(jq -r ".input_contract.triggers[$i]" "$manifest_path")"
  case "$trigger" in
    schedule) has_schedule=1 ;;
    issues_opened_title_match) has_issues_title=1 ;;
    issues_labeled_selector_match) has_issues_labeled=1 ;;
  esac
  i=$((i + 1))
done

title_pattern="$(jq -r '.input_contract.issues_opened_title_pattern // empty' "$manifest_path")"
if [ -z "$title_pattern" ]; then
  title_pattern="$name"
fi

# Construct the issue-event match clause from the trigger taxonomy.
# For issues_labeled_selector_match: read selector.include[] values
# from the manifest (NOT from string literals in this script) and
# build a contains(github.event.label.name, '<label>') OR-chain. This
# is the AC7 invariant — the renderer source carries no protocol-
# qualifier or dispatch-label literals; the labels flow through jq.
issue_event_match=""
if [ "$has_issues_labeled" -eq 1 ]; then
  include_count="$(jq -r '.selector.include | length' "$manifest_path")"
  j=0
  while [ "$j" -lt "$include_count" ]; do
    label_value="$(jq -r ".selector.include[$j]" "$manifest_path")"
    clause="contains(github.event.label.name, '${label_value}')"
    if [ -z "$issue_event_match" ]; then
      issue_event_match="$clause"
    else
      issue_event_match="${issue_event_match} || ${clause}"
    fi
    j=$((j + 1))
  done
  # Wrap the OR-chain so the outer event-name conjunction binds correctly.
  if [ "$include_count" -gt 1 ]; then
    issue_event_match="(${issue_event_match})"
  fi
elif [ "$has_issues_title" -eq 1 ]; then
  issue_event_match="contains(github.event.issue.title, '${title_pattern}')"
fi

job_if=""
if [ "$has_schedule" -eq 1 ] && [ -n "$issue_event_match" ]; then
  if [ "$has_issues_title" -eq 1 ]; then
    # Admin shape — preserve the cycle/476 byte-identical golden:
    # `event_name == 'schedule' || contains(github.event.issue.title, '<pattern>')`
    # (no explicit event_name == 'issues' check; the issue-title
    # contains() returns false at schedule firing time, so the
    # schedule short-circuit is sufficient for admin).
    job_if="    if: \${{ github.event_name == 'schedule' || ${issue_event_match} }}"
  else
    # Dispatch shape — github.event.label is undefined at schedule
    # firing time, so we explicitly gate the issue clause on the
    # event being 'issues'. This is the OG-2 guardrail: schedule
    # events fire the sweep unconditionally; issue events fire only
    # when the labeled label is in the selector's include set.
    job_if="    if: \${{ github.event_name == 'schedule' || (github.event_name == 'issues' && ${issue_event_match}) }}"
  fi
elif [ -n "$issue_event_match" ]; then
  job_if="    if: \${{ ${issue_event_match} }}"
fi

{
  echo "jobs:"
  echo "  wake:"
  if [ -n "$job_if" ]; then
    echo "$job_if"
  fi
  echo "    runs-on: ubuntu-latest"
  echo "    steps:"
  echo "      - uses: actions/checkout@v4"
  echo "        with:"
  echo "          token: \${{ secrets.SIGMA_WORKFLOW_PAT }}"
  if [ "$activation_log_writer" = "false" ]; then
    echo ""
    echo "      - name: Write fence — record pre-work baseline SHA"
    echo "        # Mechanical guard per cnos#496 / cycle/496 R1 + R2 (δ-direct iterate-narrowlies)."
    echo "        # Records the local HEAD before the claude-code-action work phase so the"
    echo "        # post-run fence can compare \$CN_WAKE_BASE_SHA..HEAD against this stable"
    echo "        # baseline — not against reflog-derived HEAD@{1}, which is unsafe for"
    echo "        # multi-commit work phases (HEAD@{1} is the IMMEDIATELY-previous HEAD, so"
    echo "        # a wake that creates two commits where the FIRST writes .cn-*/logs/ and"
    echo "        # the SECOND does not would escape a HEAD@{1}..HEAD check). The fence"
    echo "        # below prefers \$CN_WAKE_BASE_SHA → \$GITHUB_SHA → HEAD@{1} in that order."
    echo "        shell: bash"
    echo "        run: |"
    echo "          set -euo pipefail"
    echo "          echo \"CN_WAKE_BASE_SHA=\$(git rev-parse HEAD)\" >> \"\$GITHUB_ENV\""
  fi
  echo ""
  echo "      - uses: anthropics/claude-code-action@v1"
  echo "        with:"
  echo "          claude_code_oauth_token: \${{ secrets.CLAUDE_CODE_OAUTH_TOKEN }}"
  echo "          github_token: \${{ secrets.SIGMA_WORKFLOW_PAT }}"
  echo "          bot_name: \"${bot_name}\""
  echo "          bot_id: \"${bot_id}\""
  echo "          settings: |"
  echo "            {"
  echo "              \"permissions\": {"
  echo "                \"allow\": [\"Read\", \"Write\", \"Edit\", \"MultiEdit\", \"Glob\", \"Grep\", \"Bash\"]"
  echo "              }"
  echo "            }"
  echo "          prompt: |"
} >> "$tmp_out"

# Inline the prompt template body verbatim, with {agent} substitution
# per wake-provider/SKILL.md §2.3 step 6 + agent_variable §2.2. Each
# line is indented 12 spaces (4 of `prompt: |` block + 8 to keep YAML
# readable inside the steps[].with: scope). This matches the
# substrate's `prompt: |` literal-block-scalar convention.
sed "s/{agent}/${agent}/g" "$prompt_path" | sed 's/^/            /; s/[[:space:]]*$//' >> "$tmp_out"

# ---------------------------------------------------------------------------
# Append the activation-log write fence step when the manifest declares
# activation_log_writer:false (per cnos#496 / cycle/496 D2(a); AGENT-
# ACTIVATION-LOG-v0 §0.1 wake-class writer ownership).
# ---------------------------------------------------------------------------
#
# The fence is workflow-level: a final `run:` step (after the claude-
# code-action work phase) that inspects this wake's LOCAL working-tree
# state + this run's commit graph for paths under .cn-{agent}/logs/
# (glob: '.cn-*/logs/'). Non-empty result → the workflow fails with
# `dispatch_activation_log_write_violation` (an annotated error +
# nonzero exit). The fence is local-scoped, not remote-state-delta —
# it does NOT compare main@before to main@after, which would false-
# positive on legitimate concurrent admin-wake writes (different
# concurrency group, parallel execution).
#
# Two local-scope checks compose:
#   1. `git status --porcelain -- '.cn-*/logs/'` — catches uncommitted
#      writes (staged + unstaged) in the runner's working tree at fence
#      time. The work phase may have committed-and-pushed; this catches
#      anything still in the working tree.
#   2. `git log $CN_WAKE_BASE_SHA..HEAD --name-only -- '.cn-*/logs/'`
#      — catches paths committed by this run's commit graph. NO
#      --diff-filter is applied (cycle/496 R2 / operator iterate-
#      narrowly): a committed DELETE of a tracked .cn-*/logs/ path is
#      a write/ownership violation per AGENT-ACTIVATION-LOG-v0 §0.1
#      and per cnos#496's "any path under .cn-{agent}/logs/ changed by
#      the dispatch wake must fail" framing. The default `git log
#      --name-only` (no diff-filter) includes additions, copies,
#      modifications, renames, deletions, AND type changes — every
#      shape of "the wake touched this path" counts. CN_WAKE_BASE_SHA
#      is recorded by an EXPLICIT pre-work step that runs BEFORE the
#      claude-code-action work phase (cycle/496 R1; operator iterate-
#      narrowly). This is a stable baseline for ANY commit shape the
#      work phase produces — one commit, many commits, no commits —
#      and is robust against the multi-commit escape case that defeats
#      reflog-derived HEAD@{1} (where commit 1 writes .cn-*/logs/ and
#      commit 2 changes something else; HEAD@{1} points only at commit
#      2's parent so commit 1's write would be invisible to a
#      HEAD@{1}..HEAD check). Fallback chain when CN_WAKE_BASE_SHA is
#      unavailable: GITHUB_SHA (commit checked out at job start) →
#      HEAD@{1} (last resort) → working-tree-only.
#
# The fence does NOT run `git fetch` first — by design, it inspects
# only what this wake's local execution touched, never remote state.
#
# Implementation note (sh-shape consistency with the rest of the
# rendered file): the fence step uses `bash -euo pipefail` explicitly
# (the GHA default is `bash -e {0}` per cycle/485 FN; explicit
# pipefail + nounset matches the install-wake-golden.yml strict-mode
# pattern).
if [ "$activation_log_writer" = "false" ]; then
  {
    echo ""
    echo "      - name: Write fence — dispatch_activation_log_write_violation"
    echo "        # Mechanical guard per cnos#496 / cycle/496 (AGENT-ACTIVATION-LOG-v0 §0.1)."
    echo "        # Package-dispatch wakes are non-writers of .cn-{agent}/logs/. This step"
    echo "        # inspects this wake's LOCAL writes (working-tree state + this run's local"
    echo "        # commit graph) and fails the workflow if any path under .cn-*/logs/ was"
    echo "        # touched. The check is local-scoped, NOT remote-state-delta — it does NOT"
    echo "        # fetch or compare against origin/main, which would false-positive on"
    echo "        # legitimate concurrent admin-wake writes (different concurrency group)."
    echo "        if: always()"
    echo "        shell: bash"
    echo "        run: |"
    echo "          set -euo pipefail"
    echo "          # Pathspec uses git's :(glob) magic — a bare '.cn-*/logs/' is"
    echo "          # treated literally by git and matches nothing. The :(glob)"
    echo "          # prefix enables shell-style globbing and the trailing /**"
    echo "          # matches files at any depth under .cn-{agent}/logs/."
    echo "          pathspec=':(glob).cn-*/logs/**'"
    echo "          violation=0"
    echo "          # Layer 1: working-tree state (staged + unstaged uncommitted writes)."
    echo "          wt=\"\$(git status --porcelain -- \"\$pathspec\" 2>/dev/null || true)\""
    echo "          if [ -n \"\$wt\" ]; then"
    echo "            violation=1"
    echo "            echo \"::error::dispatch_activation_log_write_violation: local working-tree writes detected under .cn-*/logs/\""
    echo "            echo \"\$wt\""
    echo "          fi"
    echo "          # Layer 2: local commit graph this run added — \$CN_WAKE_BASE_SHA..HEAD."
    echo "          # cycle/496 R1 (operator iterate-narrowly): the primary baseline is"
    echo "          # \$CN_WAKE_BASE_SHA, captured by the 'Write fence — record pre-work"
    echo "          # baseline SHA' step BEFORE the claude-code-action work phase. This is"
    echo "          # the stable, explicit baseline — reliable for ANY commit shape the work"
    echo "          # phase produces (one commit, many commits, no commits). Fallback chain:"
    echo "          #   (1) \$CN_WAKE_BASE_SHA — primary; recorded by the pre-work baseline step."
    echo "          #   (2) \$GITHUB_SHA       — fallback; the commit checked out at job start."
    echo "          #   (3) HEAD@{1}          — last resort; reflog-derived; UNSAFE for multi-"
    echo "          #                           commit work phases (catches only the most"
    echo "          #                           recent commit's parent, NOT the pre-work baseline)."
    echo "          # On none-of-the-above, log a notice but do NOT false-fail; the working-"
    echo "          # tree check above is the primary fence."
    echo "          # cycle/496 R2 (operator iterate-narrowly): NO --diff-filter is applied."
    echo "          # A committed DELETE of a tracked .cn-*/logs/ path is a write/ownership"
    echo "          # violation per AGENT-ACTIVATION-LOG-v0 §0.1 and per cnos#496's framing"
    echo "          # ('any path under .cn-{agent}/logs/ changed by the dispatch wake must"
    echo "          # fail'). Default \`git log --name-only\` (no diff-filter) catches"
    echo "          # additions, copies, modifications, renames, deletions, AND type changes."
    echo "          commits=\"\""
    echo "          if [ -n \"\${CN_WAKE_BASE_SHA:-}\" ] && git rev-parse --verify \"\$CN_WAKE_BASE_SHA\" >/dev/null 2>&1 && [ \"\$(git rev-parse HEAD)\" != \"\$CN_WAKE_BASE_SHA\" ]; then"
    echo "            commits=\"\$(git log \"\${CN_WAKE_BASE_SHA}..HEAD\" --name-only --pretty=format: -- \"\$pathspec\" 2>/dev/null | grep -v '^\$' || true)\""
    echo "          elif [ -n \"\${GITHUB_SHA:-}\" ] && git rev-parse --verify \"\$GITHUB_SHA\" >/dev/null 2>&1 && [ \"\$(git rev-parse HEAD)\" != \"\$GITHUB_SHA\" ]; then"
    echo "            commits=\"\$(git log \"\${GITHUB_SHA}..HEAD\" --name-only --pretty=format: -- \"\$pathspec\" 2>/dev/null | grep -v '^\$' || true)\""
    echo "          elif git rev-parse --verify HEAD@{1} >/dev/null 2>&1; then"
    echo "            commits=\"\$(git log HEAD@{1}..HEAD --name-only --pretty=format: -- \"\$pathspec\" 2>/dev/null | grep -v '^\$' || true)\""
    echo "          else"
    echo "            echo \"::notice::write-fence: local commit-graph baseline unavailable (no CN_WAKE_BASE_SHA, no GITHUB_SHA divergence, no HEAD@{1} reflog); working-tree check is the primary fence.\""
    echo "          fi"
    echo "          if [ -n \"\$commits\" ]; then"
    echo "            violation=1"
    echo "            echo \"::error::dispatch_activation_log_write_violation: local commit-graph writes detected under .cn-*/logs/\""
    echo "            echo \"\$commits\""
    echo "          fi"
    echo "          if [ \"\$violation\" -ne 0 ]; then"
    echo "            echo \"dispatch_activation_log_write_violation: package-dispatch wakes are non-writers of .cn-{agent}/logs/ per AGENT-ACTIVATION-LOG-v0 §0.1.\" >&2"
    echo "            exit 1"
    echo "          fi"
    echo "          echo \"write-fence: no local writes under .cn-*/logs/ — green.\""
  } >> "$tmp_out"
fi

# ---------------------------------------------------------------------------
# Append the mechanical checkpoint + PR-open/update finalizer step (cnos#591).
# ---------------------------------------------------------------------------
#
# Governing rule: if a run ends with matter, there must be a branch/commit/
# pull-request — or an explicit blocked/STOP record. A cell must never be
# left with work on the branch (or only in the workspace) and no pull
# request open. Checkpoint + PR creation are a MECHANICAL runtime/finalizer
# responsibility, not a step a cognitive work session has to remember to
# reach: workers produce matter; this step checkpoints (commit + push) and
# opens/updates the pull request; lifecycle status labels remain owned
# entirely elsewhere (this step never mutates one and never requests a
# transition).
#
# This step is a SIBLING to the write-fence step above — added, not
# interleaved into it — and follows the identical `if: always()` +
# $CN_WAKE_BASE_SHA baseline convention (cnos#496), but is gated on a
# DIFFERENT concern: role == "dispatch", read from the same $role shell
# variable the manifest validation block earlier in this script already
# computed. This is NOT the activation_log_writer gate used by the write
# fence above — that variable governs channel-log write ownership, an
# independent concern that happens to currently coincide with this one for
# a single existing wake. Gating on role keeps this finalizer applicable to
# any future dispatch-shaped wake uniformly, consistent with the renderer's
# protocol-agnostic architecture (the renderer never encodes a concrete
# protocol name or label taxonomy; see the AC7/AC8 leak-audit in
# install-wake-golden.yml, which this step's wording is written to keep
# clean).
#
# `if: always()`: the finalizer must run even when the work-phase step
# above failed or timed out — a work session that dies mid-flight with
# matter already produced is exactly the failure mode this mechanism
# exists to close off; it must not depend on the work phase having
# succeeded or even having reached its own final step.
#
# The step builds the kernel binary fresh from source (rather than
# assuming a pre-built binary is on PATH) and invokes the finalize
# sub-verb with no explicit issue number: the command self-detects its
# target from the checked-out branch name, or — failing that — from which
# CDD artifact directory under .cdd/unreleased/ carries matter, since the
# renderer cannot know the issue number in advance for an arbitrary future
# dispatch-shaped wake.
if [ "$role" = "dispatch" ]; then
  {
    echo ""
    echo "      - name: Mechanical checkpoint + PR finalizer"
    echo "        # Runtime/finalizer guard per cnos#591: if this run ends with matter"
    echo "        # (uncommitted changes, commits beyond base, CDD artifacts, or an"
    echo "        # existing cycle branch), there must be a checkpoint + an open pull"
    echo "        # request — never a cell silently stranded with matter and no PR."
    echo "        # This step never mutates a lifecycle label and never requests a"
    echo "        # transition; it only commits/pushes matter and ensures a draft PR."
    echo "        if: always()"
    echo "        shell: bash"
    echo "        run: |"
    echo "          set -euo pipefail"
    echo "          (cd src/go && go build -o /tmp/cn-finalize ./cmd/cn)"
    echo "          /tmp/cn-finalize cell finalize --base-sha \"\${CN_WAKE_BASE_SHA:-}\""
  } >> "$tmp_out"
fi

# ---------------------------------------------------------------------------
# Idempotent write
# ---------------------------------------------------------------------------

# Ensure output directory exists.
out_dir="$(dirname "$out_path")"
[ -d "$out_dir" ] || mkdir -p "$out_dir"

if [ -f "$out_path" ] && cmp -s "$tmp_out" "$out_path"; then
  echo "cn-install-wake: ${name} → ${out_path} (unchanged)"
else
  cp "$tmp_out" "$out_path"
  echo "cn-install-wake: ${name} → ${out_path} (rendered)"
fi
