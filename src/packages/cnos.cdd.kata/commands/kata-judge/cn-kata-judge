#!/usr/bin/env bash
set -euo pipefail

if [ $# -eq 0 ]; then
  echo "Usage: cn kata-judge <run-dir>"
  exit 1
fi

RUN_DIR="$1"

[ -f "$RUN_DIR/metadata.json" ] || { echo "ERROR: $RUN_DIR/metadata.json not found"; exit 1; }

KATA_ID="$(python3 -c "import json; print(json.load(open('$RUN_DIR/metadata.json'))['kata_id'])")"
MODE="$(python3 -c "import json; print(json.load(open('$RUN_DIR/metadata.json')).get('mode','unknown'))")"
STATUS="$(python3 -c "import json; print(json.load(open('$RUN_DIR/metadata.json')).get('status','unknown'))")"

cat <<EOF
{
  "kata_id": "$KATA_ID",
  "mode": "$MODE",
  "status": "$STATUS",
  "verdict": "not-yet-implemented",
  "note": "CDD method judge contract exists, but fixed LLM judge wiring is not yet landed"
}
EOF
