#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
KATAS_DIR="$SCRIPT_DIR/katas/method"

MODE=""
KATA_ID=""
OUT_DIR=""

usage() {
  cat <<EOF
Usage: cn kata-run <kata-id> --mode baseline|cdd [--out <dir>]

Runs one CDD method kata and captures a run bundle.
EOF
  exit 1
}

while [ $# -gt 0 ]; do
  case "$1" in
    --mode) MODE="${2:-}"; shift 2 ;;
    --out)  OUT_DIR="${2:-}"; shift 2 ;;
    -h|--help) usage ;;
    *)
      if [ -z "$KATA_ID" ]; then
        KATA_ID="$1"; shift
      else
        usage
      fi
      ;;
  esac
done

[ -n "$KATA_ID" ] || usage
[ "$MODE" = "baseline" ] || [ "$MODE" = "cdd" ] || usage

KATA_DIR="$KATAS_DIR/$KATA_ID"
[ -d "$KATA_DIR" ] || { echo "ERROR: kata '$KATA_ID' not found"; exit 1; }

if [ -z "$OUT_DIR" ]; then
  RUN_ID="$(date +%Y%m%d-%H%M%S)-${KATA_ID}-${MODE}"
  OUT_DIR=".kata-runs/$RUN_ID"
fi

mkdir -p "$OUT_DIR/artifacts"

if [ ! -f "$KATA_DIR/run.sh" ]; then
  echo "SKIP: $KATA_ID — corpus exists but run harness not implemented yet"
  cat > "$OUT_DIR/metadata.json" <<EOF
{
  "kata_id": "$KATA_ID",
  "mode": "$MODE",
  "status": "stub",
  "failures": -1,
  "passes": 0
}
EOF
  exit 0
fi

bash "$KATA_DIR/run.sh" "$MODE" "$OUT_DIR"
