#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
KATAS_DIR="$SCRIPT_DIR/../kata-run/katas/method"

echo "CDD Method Kata Suite"
echo ""

for kata_dir in "$KATAS_DIR"/*/; do
  [ -d "$kata_dir" ] || continue
  id="$(basename "$kata_dir")"
  name=""
  if [ -f "$kata_dir/rubric.json" ]; then
    name="$(python3 -c "import json; print(json.load(open('$kata_dir/rubric.json')).get('name',''))" 2>/dev/null || true)"
  fi
  has_run="○"
  [ -f "$kata_dir/run.sh" ] && has_run="●"
  printf "  %s %-20s %s\n" "$has_run" "$id" "$name"
done

echo ""
echo "● = executable  ○ = corpus-only"
echo ""
echo "Run:  cn kata-run <kata-id> --mode baseline|cdd"
