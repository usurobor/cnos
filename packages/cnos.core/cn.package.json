{
  "schema": "cn.package.v1",
  "name": "cnos.core",
  "version": "3.41.0",
  "kind": "package",
  "engines": {
    "cnos": "3.41.0"
  },
  "sources": {
    "doctrine": [
      "*"
    ],
    "mindsets": [
      "CURIOSITY.md",
      "ENGINEERING.md",
      "FUNCTIONAL.md",
      "MEMES.md",
      "OPERATIONS.md",
      "PERSONALITY.md",
      "PM.md",
      "THINKING.md",
      "WISDOM.md"
    ],
    "skills": [
      "agent/agent-ops",
      "agent/ca-conduct",
      "agent/cap",
      "agent/cbp",
      "agent/clp",
      "agent/coherence-test",
      "agent/coherent",
      "agent/communicating",
      "agent/configure-agent",
      "agent/emoji-language",
      "agent/hello-world",
      "agent/human-interaction",
      "agent/mca",
      "agent/mci",
      "agent/onboarding",
      "agent/reflect",
      "agent/self-cohere",
      "cdd",
      "cdd/design",
      "cdd/issue",
      "cdd/plan",
      "cdd/post-release",
      "cdd/release",
      "cdd/review",
      "ops/adhoc-thread",
      "ops/inbox",
      "ops/peer",
      "ops/star-sync"
    ],
    "extensions": [
      "cnos.net.http"
    ],
    "templates": [
      "SOUL.md",
      "USER.md"
    ],
    "orchestrators": [
      "daily-review"
    ],
    "commands": [
      "daily",
      "save",
      "weekly"
    ]
  },
  "commands": {
    "daily": {
      "entrypoint": "commands/daily/cn-daily",
      "summary": "Create or show today's daily reflection thread"
    },
    "weekly": {
      "entrypoint": "commands/weekly/cn-weekly",
      "summary": "Create or show the current weekly reflection thread"
    },
    "save": {
      "entrypoint": "commands/save/cn-save",
      "summary": "Commit + push (shorthand for `cn commit` then `cn push`)"
    }
  }
}
